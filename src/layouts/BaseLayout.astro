---
import '../styles/global.css'
import { ClientRouter } from 'astro:transitions'

interface Props {
  title: string
  description?: string
  ogImage?: string
  /** Set to false only for noindex pages like /dev/components */
  indexable?: boolean
}

const {
  title,
  description = 'Banua Coder — Technology partner for websites, apps, and operational systems.',
  ogImage = '/og-default.png',
  indexable = true,
} = Astro.props

const locale = Astro.currentLocale ?? 'id'
const isEn = locale === 'en'

// Build alternate hreflang URLs
const currentPath = Astro.url.pathname
const idPath = isEn ? currentPath.replace(/^\/en/, '') || '/' : currentPath
const enPath = isEn ? currentPath : `/en${currentPath === '/' ? '' : currentPath}`
const idUrl = new URL(idPath, Astro.site).href
const enUrl = new URL(enPath, Astro.site).href

// Detect /dev/ routes to force noindex
const isDevRoute = currentPath.startsWith('/dev/')
const shouldIndex = indexable && !isDevRoute
---

<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="robots" content={shouldIndex ? 'index, follow' : 'noindex, nofollow'} />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!--
      Critical font preloads — Geist (display/headlines) and Inter (body).
      These are variable fonts; the latin subset covers all site copy.
      crossorigin is required for font preloads even for same-origin files.
      Actual filenames are hashed by Vite; these preloads use the @fontsource
      paths directly before Vite hashing — browsers will de-dupe via
      Content-Type match when the stylesheet fires.
    -->
    <link
      rel="preload"
      as="font"
      type="font/woff2"
      href="/@fontsource-variable/geist/files/geist-latin-wght-normal.woff2"
      crossorigin
    />
    <link
      rel="preload"
      as="font"
      type="font/woff2"
      href="/@fontsource-variable/inter/files/inter-latin-wght-normal.woff2"
      crossorigin
    />

    <!-- Theme color — deep blue works on light and dark OS chrome -->
    <meta name="theme-color" media="(prefers-color-scheme: light)" content="#F7F7F4" />
    <meta name="theme-color" media="(prefers-color-scheme: dark)" content="#0A0E14" />

    <!-- hreflang alternate links -->
    <link rel="alternate" hreflang="id" href={idUrl} />
    <link rel="alternate" hreflang="en" href={enUrl} />
    <link rel="alternate" hreflang="x-default" href={idUrl} />

    <!-- Canonical URL -->
    <link rel="canonical" href={Astro.url.href.split('?')[0].split('#')[0]} />

    <!-- OG locale -->
    <meta property="og:locale" content={isEn ? 'en_US' : 'id_ID'} />
    <meta property="og:locale:alternate" content={isEn ? 'id_ID' : 'en_US'} />

    <!-- OpenGraph basics -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={Astro.url.href} />
    <meta property="og:image" content={new URL(ogImage, Astro.site).href} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content="@banuacoder" />
    <meta name="twitter:creator" content="@ryanaidilp_" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL(ogImage, Astro.site).href} />

    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>

    <!-- View transitions — Astro built-in fade-slide between routes -->
    <ClientRouter fallback="animate" />

    <!-- Page-specific head content (meta, structured data, etc.) -->
    <slot name="head" />

    <!-- FOUC prevention: read localStorage.theme before first paint -->
    <script is:inline>
      (function () {
        try {
          var stored = localStorage.getItem('theme');
          if (stored === 'dark') {
            document.documentElement.classList.add('dark');
          } else if (stored === 'light') {
            document.documentElement.classList.remove('dark');
          } else if (window.matchMedia('(prefers-color-scheme: dark)').matches) {
            document.documentElement.classList.add('dark');
          }
        } catch (e) {}
      })();
    </script>
  </head>
  <body>
    <slot />
  </body>

  <script>
    import { initAnimations } from '../lib/animations'

    let cleanup: (() => void) | null = null

    function boot() {
      cleanup?.()
      cleanup = initAnimations()
    }

    boot()

    // Re-init after Astro view transitions swap
    document.addEventListener('astro:after-swap', boot)
  </script>
</html>
