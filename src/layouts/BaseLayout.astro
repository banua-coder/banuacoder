---
import '../styles/global.css'
import { ClientRouter } from 'astro:transitions'

interface Props {
  title: string
  description?: string
  ogImage?: string
  /** Set to false only for noindex pages like /dev/components */
  indexable?: boolean
}

const {
  title,
  description = 'Banua Coder — Technology partner for websites, apps, and operational systems.',
  ogImage = '/og-default.png',
  indexable = true,
} = Astro.props

const locale = Astro.currentLocale ?? 'id'
const isEn = locale === 'en'

// Build alternate hreflang URLs
const currentPath = Astro.url.pathname
const idPath = isEn ? currentPath.replace(/^\/en/, '') || '/' : currentPath
const enPath = isEn ? currentPath : `/en${currentPath === '/' ? '' : currentPath}`
const idUrl = new URL(idPath, Astro.site).href
const enUrl = new URL(enPath, Astro.site).href

// Detect /dev/ routes to force noindex
const isDevRoute = currentPath.startsWith('/dev/')
const shouldIndex = indexable && !isDevRoute
---

<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="robots" content={shouldIndex ? 'index, follow' : 'noindex, nofollow'} />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!--
      Critical font preloads — Geist (display/headlines) and Inter (body).
      These are variable fonts; the latin subset covers all site copy.
      crossorigin is required for font preloads even for same-origin files.
      Actual filenames are hashed by Vite; these preloads use the @fontsource
      paths directly before Vite hashing — browsers will de-dupe via
      Content-Type match when the stylesheet fires.
    -->
    <link
      rel="preload"
      as="font"
      type="font/woff2"
      href="/@fontsource-variable/geist/files/geist-latin-wght-normal.woff2"
      crossorigin
    />
    <link
      rel="preload"
      as="font"
      type="font/woff2"
      href="/@fontsource-variable/inter/files/inter-latin-wght-normal.woff2"
      crossorigin
    />

    <!-- Theme color — deep blue works on light and dark OS chrome -->
    <meta name="theme-color" media="(prefers-color-scheme: light)" content="#F7F7F4" />
    <meta name="theme-color" media="(prefers-color-scheme: dark)" content="#0A0E14" />

    <!-- hreflang alternate links -->
    <link rel="alternate" hreflang="id" href={idUrl} />
    <link rel="alternate" hreflang="en" href={enUrl} />
    <link rel="alternate" hreflang="x-default" href={idUrl} />

    <!-- Canonical URL -->
    <link rel="canonical" href={Astro.url.href.split('?')[0].split('#')[0]} />

    <!-- OG locale -->
    <meta property="og:locale" content={isEn ? 'en_US' : 'id_ID'} />
    <meta property="og:locale:alternate" content={isEn ? 'id_ID' : 'en_US'} />

    <!-- OpenGraph basics -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={Astro.url.href} />
    <meta property="og:image" content={new URL(ogImage, Astro.site).href} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content="@banuacoder" />
    <meta name="twitter:creator" content="@ryanaidilp_" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL(ogImage, Astro.site).href} />

    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>

    <!-- View transitions — Astro built-in fade-slide between routes -->
    <ClientRouter fallback="animate" />

    <!-- Page-specific head content (meta, structured data, etc.) -->
    <slot name="head" />

    <!-- FOUC prevention: read localStorage.theme before first paint -->
    <script is:inline>
      (function () {
        try {
          var stored = localStorage.getItem('theme');
          if (stored === 'dark') {
            document.documentElement.classList.add('dark');
          } else if (stored === 'light') {
            document.documentElement.classList.remove('dark');
          } else if (window.matchMedia('(prefers-color-scheme: dark)').matches) {
            document.documentElement.classList.add('dark');
          }
        } catch (e) {}
      })();
    </script>
  </head>
  <body>
    <!--
      Page loader — full-viewport overlay shown immediately on first paint.
      Inline CSS so it renders before any stylesheet downloads, inline JS
      hides it on window.load (with 4s safety timeout). Survives view
      transitions because it ONLY appears on initial document load — once
      faded out, the next route swap doesn't re-mount this overlay.
    -->
    <div id="page-loader" aria-hidden="true">
      <div class="page-loader-inner">
        <svg
          class="page-loader-mark"
          xmlns="http://www.w3.org/2000/svg"
          viewBox="193 745 165 130"
          fill="none"
          fill-rule="evenodd"
          aria-label="Banua Coder"
        >
          <path d="M246.91,763.974l6.66,6.661c-10.99,8.825 -18.115,22.954 -18.115,38.867c0,15.912 7.125,30.042 18.115,38.867l-6.66,6.66c-12.681,-10.582 -20.835,-27.047 -20.835,-45.527c-0,-18.48 8.154,-34.946 20.835,-45.528Z" fill="#1d9cd4"/>
          <path d="M259.8,863.013c-4.628,2.713 -10.015,4.269 -15.762,4.269l-47.601,-0l-0,-40.616c-0,-6.885 -5.59,-12.474 -12.475,-12.474c0,0 0,-9.38 0,-9.38c6.885,-0 12.475,-5.59 12.475,-12.475l-0,-40.615l47.601,-0l0.101,0c5.71,0.019 11.061,1.572 15.66,4.268c6.314,-2.751 13.224,-4.268 20.463,-4.268c18.578,-0 34.985,9.991 44.75,25.205l-6.817,6.817c-7.937,-13.6 -21.965,-22.642 -37.933,-22.642c-4.248,0 -8.36,0.641 -12.255,1.836c4.535,5.422 7.266,12.404 7.266,20.019c-0,11.2 -5.908,21.031 -14.775,26.545c8.867,5.513 14.775,15.344 14.775,26.545c-0,7.614 -2.731,14.596 -7.266,20.018c3.896,1.196 8.007,1.836 12.255,1.836c18.318,0 34.082,-11.898 41.028,-28.927l7.096,7.096c-9.027,18.536 -27.198,31.212 -48.124,31.212c-7.239,-0 -14.149,-1.517 -20.462,-4.269Zm-53.983,-5.112l0,-31.235c0,-6.958 -3.259,-13.162 -8.332,-17.164c5.073,-4.003 8.332,-10.206 8.332,-17.165l0,-31.235l38.221,0c12.062,0 21.854,9.793 21.854,21.855c0,12.062 -9.792,21.855 -21.854,21.855l-0,9.38c12.062,0 21.854,9.793 21.854,21.855c0,12.037 -9.753,21.815 -21.784,21.854l-0.07,0l-38.221,0Z" fill="#12398C"/>
        </svg>
        <div class="page-loader-bar"><span></span></div>
      </div>
    </div>
    <style is:inline>
      #page-loader {
        position: fixed;
        inset: 0;
        z-index: 9999;
        display: flex;
        align-items: center;
        justify-content: center;
        background: #f7f7f4;
        transition: opacity 0.45s ease, visibility 0.45s ease;
      }
      :root.dark #page-loader { background: #0a0e14; }
      .page-loader-inner {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 24px;
      }
      .page-loader-mark {
        width: 72px;
        height: auto;
        animation: page-loader-pulse 1.6s ease-in-out infinite;
      }
      :root.dark .page-loader-mark path:last-child {
        fill: #f7f7f4;
      }
      .page-loader-bar {
        position: relative;
        width: 140px;
        height: 2px;
        background: rgba(18, 57, 140, 0.12);
        overflow: hidden;
        border-radius: 999px;
      }
      :root.dark .page-loader-bar { background: rgba(29, 156, 212, 0.2); }
      .page-loader-bar > span {
        position: absolute;
        inset: 0;
        background: linear-gradient(90deg, transparent, #12398c, transparent);
        animation: page-loader-slide 1.2s linear infinite;
      }
      :root.dark .page-loader-bar > span {
        background: linear-gradient(90deg, transparent, #1d9cd4, transparent);
      }
      #page-loader.is-hidden {
        opacity: 0;
        visibility: hidden;
      }
      @keyframes page-loader-pulse {
        0%, 100% { opacity: 1; transform: scale(1); }
        50%      { opacity: 0.7; transform: scale(0.92); }
      }
      @keyframes page-loader-slide {
        0%   { transform: translateX(-100%); }
        100% { transform: translateX(100%); }
      }
      @media (prefers-reduced-motion: reduce) {
        .page-loader-mark, .page-loader-bar > span { animation: none; }
      }
    </style>
    <script is:inline>
      (function () {
        function hide() {
          var loader = document.getElementById('page-loader');
          if (!loader) return;
          loader.classList.add('is-hidden');
          window.setTimeout(function () {
            if (loader.parentNode) loader.parentNode.removeChild(loader);
          }, 500);
        }
        if (document.readyState === 'complete') {
          hide();
        } else {
          window.addEventListener('load', hide, { once: true });
          window.setTimeout(hide, 4000);
        }
        // View transitions inject a fresh loader on every navigation —
        // remove it immediately, transitions handle their own loading visual.
        document.addEventListener('astro:after-swap', hide);
      })();
    </script>

    <slot />
  </body>

  <script>
    import { initAnimations } from '../lib/animations'

    let cleanup: (() => void) | null = null

    function boot() {
      cleanup?.()
      cleanup = initAnimations()
    }

    boot()

    // Re-init after Astro view transitions swap
    document.addEventListener('astro:after-swap', boot)
  </script>
</html>
