---
import '../styles/global.css'
import { ClientRouter } from 'astro:transitions'

interface Props {
  title: string
  description?: string
  ogImage?: string
  /** Set to false only for noindex pages like /dev/components */
  indexable?: boolean
}

const {
  title,
  description = 'Banua Coder — Technology partner for websites, apps, and operational systems.',
  ogImage = '/og-default.png',
  indexable = true,
} = Astro.props

const locale = Astro.currentLocale ?? 'id'
const isEn = locale === 'en'

// Build alternate hreflang URLs
const currentPath = Astro.url.pathname
const idPath = isEn ? currentPath.replace(/^\/en/, '') || '/' : currentPath
const enPath = isEn ? currentPath : `/en${currentPath === '/' ? '' : currentPath}`
const idUrl = new URL(idPath, Astro.site).href
const enUrl = new URL(enPath, Astro.site).href

// Detect /dev/ routes to force noindex
const isDevRoute = currentPath.startsWith('/dev/')
const shouldIndex = indexable && !isDevRoute
---

<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="robots" content={shouldIndex ? 'index, follow' : 'noindex, nofollow'} />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!--
      Critical font preloads — Geist (display/headlines) and Inter (body).
      These are variable fonts; the latin subset covers all site copy.
      crossorigin is required for font preloads even for same-origin files.
      Actual filenames are hashed by Vite; these preloads use the @fontsource
      paths directly before Vite hashing — browsers will de-dupe via
      Content-Type match when the stylesheet fires.
    -->
    <link
      rel="preload"
      as="font"
      type="font/woff2"
      href="/@fontsource-variable/geist/files/geist-latin-wght-normal.woff2"
      crossorigin
    />
    <link
      rel="preload"
      as="font"
      type="font/woff2"
      href="/@fontsource-variable/inter/files/inter-latin-wght-normal.woff2"
      crossorigin
    />

    <!-- Theme color — deep blue works on light and dark OS chrome -->
    <meta name="theme-color" media="(prefers-color-scheme: light)" content="#F7F7F4" />
    <meta name="theme-color" media="(prefers-color-scheme: dark)" content="#0A0E14" />

    <!-- hreflang alternate links -->
    <link rel="alternate" hreflang="id" href={idUrl} />
    <link rel="alternate" hreflang="en" href={enUrl} />
    <link rel="alternate" hreflang="x-default" href={idUrl} />

    <!-- Canonical URL -->
    <link rel="canonical" href={Astro.url.href.split('?')[0].split('#')[0]} />

    <!-- OG locale -->
    <meta property="og:locale" content={isEn ? 'en_US' : 'id_ID'} />
    <meta property="og:locale:alternate" content={isEn ? 'id_ID' : 'en_US'} />

    <!-- OpenGraph basics -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={Astro.url.href} />
    <meta property="og:image" content={new URL(ogImage, Astro.site).href} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content="@banuacoder" />
    <meta name="twitter:creator" content="@ryanaidilp_" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL(ogImage, Astro.site).href} />

    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>

    <!-- View transitions — Astro built-in fade-slide between routes -->
    <ClientRouter fallback="animate" />

    <!-- Page-specific head content (meta, structured data, etc.) -->
    <slot name="head" />

    <!-- FOUC prevention: read localStorage.theme before first paint -->
    <script is:inline>
      (function () {
        try {
          var stored = localStorage.getItem('theme');
          if (stored === 'dark') {
            document.documentElement.classList.add('dark');
          } else if (stored === 'light') {
            document.documentElement.classList.remove('dark');
          } else if (window.matchMedia('(prefers-color-scheme: dark)').matches) {
            document.documentElement.classList.add('dark');
          }
        } catch (e) {}
      })();
    </script>
  </head>
  <body>
    <!--
      Page loader — full-viewport overlay shown immediately on first paint.
      Inline CSS so it renders before any stylesheet downloads, inline JS
      hides it on window.load (with 4s safety timeout). Survives view
      transitions because it ONLY appears on initial document load — once
      faded out, the next route swap doesn't re-mount this overlay.
    -->
    <div id="page-loader" aria-hidden="true">
      <div class="page-loader-inner">
        <svg
          class="page-loader-mark"
          xmlns="http://www.w3.org/2000/svg"
          viewBox="0 0 280 280"
          fill="none"
        >
          <rect width="280" height="280" rx="56" fill="#12398C" />
          <path
            d="M96 85.5 L99.8 89.3 C92.0 95.3 87.1 104.7 87.1 115.3 C87.1 125.9 92.0 135.3 99.8 141.3 L96 145.1 C86.8 137.3 81.1 125.9 81.1 115.3 C81.1 104.7 86.8 93.3 96 85.5 Z"
            fill="#1D9CD4"
          />
        </svg>
        <div class="page-loader-bar"><span></span></div>
      </div>
    </div>
    <style is:inline>
      #page-loader {
        position: fixed;
        inset: 0;
        z-index: 9999;
        display: flex;
        align-items: center;
        justify-content: center;
        background: #f7f7f4;
        transition: opacity 0.45s ease, visibility 0.45s ease;
      }
      :root.dark #page-loader { background: #0a0e14; }
      .page-loader-inner {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 24px;
      }
      .page-loader-mark {
        width: 64px;
        height: 64px;
        animation: page-loader-pulse 1.6s ease-in-out infinite;
      }
      .page-loader-bar {
        position: relative;
        width: 140px;
        height: 2px;
        background: rgba(18, 57, 140, 0.12);
        overflow: hidden;
        border-radius: 999px;
      }
      :root.dark .page-loader-bar { background: rgba(29, 156, 212, 0.2); }
      .page-loader-bar > span {
        position: absolute;
        inset: 0;
        background: linear-gradient(90deg, transparent, #12398c, transparent);
        animation: page-loader-slide 1.2s linear infinite;
      }
      :root.dark .page-loader-bar > span {
        background: linear-gradient(90deg, transparent, #1d9cd4, transparent);
      }
      #page-loader.is-hidden {
        opacity: 0;
        visibility: hidden;
      }
      @keyframes page-loader-pulse {
        0%, 100% { opacity: 1; transform: scale(1); }
        50%      { opacity: 0.7; transform: scale(0.92); }
      }
      @keyframes page-loader-slide {
        0%   { transform: translateX(-100%); }
        100% { transform: translateX(100%); }
      }
      @media (prefers-reduced-motion: reduce) {
        .page-loader-mark, .page-loader-bar > span { animation: none; }
      }
    </style>
    <script is:inline>
      (function () {
        var loader = document.getElementById('page-loader');
        if (!loader) return;
        var hide = function () {
          loader.classList.add('is-hidden');
          // Remove from DOM after the fade so it can't trap focus.
          window.setTimeout(function () {
            if (loader.parentNode) loader.parentNode.removeChild(loader);
          }, 500);
        };
        if (document.readyState === 'complete') {
          hide();
        } else {
          window.addEventListener('load', hide, { once: true });
          // Safety timeout: never block more than 4s even if some asset hangs.
          window.setTimeout(hide, 4000);
        }
      })();
    </script>

    <slot />
  </body>

  <script>
    import { initAnimations } from '../lib/animations'

    let cleanup: (() => void) | null = null

    function boot() {
      cleanup?.()
      cleanup = initAnimations()
    }

    boot()

    // Re-init after Astro view transitions swap
    document.addEventListener('astro:after-swap', boot)
  </script>
</html>
