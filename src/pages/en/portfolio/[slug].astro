---
import { getCollection, render } from 'astro:content'
import type { ImageMetadata } from 'astro'
import { Image } from 'astro:assets'
import BaseLayout from '../../../layouts/BaseLayout.astro'
import Nav from '../../../components/layout/Nav.astro'
import Footer from '../../../components/layout/Footer.astro'
import Container from '../../../components/layout/Container.astro'
import Tag from '../../../components/atoms/Tag.astro'
import Button from '../../../components/atoms/Button.astro'
import Prose from '../../../components/typography/Prose.astro'

export async function getStaticPaths() {
  const allPortfolio = await getCollection('portfolio')
  const enEntries = allPortfolio.filter((p) => p.data.locale === 'en')
  return enEntries.map((entry) => ({
    params: { slug: entry.data.slug },
    props: { entry },
  }))
}

const { entry } = Astro.props
const { data } = entry
const { Content } = await render(entry)

// "Next case study" — same bucket, sorted by order, cycling
const allPortfolio = await getCollection('portfolio')
const sameBucket = allPortfolio
  .filter((p) => p.data.locale === 'en' && p.data.bucket === data.bucket && p.data.slug !== data.slug)
  .sort((a, b) => a.data.order - b.data.order)
const nextProject = sameBucket.length > 0 ? sameBucket[0] : null

// Testimonials linked to this project (collection may be empty)
let linkedTestimonial = undefined
try {
  const allTestimonials = await getCollection('testimonials')
  linkedTestimonial = allTestimonials.find(
    (t) => t.data.locale === 'en' && t.data.project?.id === entry.id,
  )
} catch {
  // No testimonials yet — renders nothing
}

const bucketLabel = {
  consumer: 'Consumer',
  'public-sector': 'Public Sector',
  operational: 'Operational',
  engineering: 'Engineering',
}[data.bucket]

const bucketVariantMap: Record<string, 'bucket-consumer' | 'bucket-public' | 'bucket-operational' | 'bucket-engineering'> = {
  consumer: 'bucket-consumer',
  'public-sector': 'bucket-public',
  operational: 'bucket-operational',
  engineering: 'bucket-engineering',
}
const bucketVariant = bucketVariantMap[data.bucket] ?? 'bucket-consumer'

const statusLabel = {
  live: 'Live',
  maintained: 'Maintained',
  archived: 'Archived',
}[data.status]

// JSON-LD: CreativeWork + BreadcrumbList
const creativeWorkSchema = {
  '@context': 'https://schema.org',
  '@type': 'CreativeWork',
  name: data.title,
  description: data.summary,
  creator: {
    '@type': 'Organization',
    name: 'Banua Coder',
    url: 'https://banuacoder.com',
  },
  dateCreated: String(data.year),
  keywords: data.stack.join(', '),
  inLanguage: 'en',
}

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://banuacoder.com/en/' },
    { '@type': 'ListItem', position: 2, name: 'Portfolio', item: 'https://banuacoder.com/en/portfolio/' },
    {
      '@type': 'ListItem',
      position: 3,
      name: data.title,
      item: `https://banuacoder.com/en/portfolio/${data.slug}/`,
    },
  ],
}
---

<BaseLayout
  title={`${data.title} — Portfolio · Banua Coder`}
  description={data.summary}
>
  <script is:inline type="application/ld+json" slot="head" set:html={JSON.stringify(creativeWorkSchema)} />
  <script is:inline type="application/ld+json" slot="head" set:html={JSON.stringify(breadcrumbSchema)} />

  <a
    href="#main-content"
    class="sr-only focus:not-sr-only focus:fixed focus:top-4 focus:left-4 focus:z-[9999] focus:px-4 focus:py-2 focus:bg-bnc-primary focus:text-white focus:rounded-[var(--radius-sm)]"
  >
    Skip to main content
  </a>

  <Nav />

  <main id="main-content">
    <!-- Hero: cover image full-width -->
    <section
      aria-labelledby="project-title"
      class="relative border-b border-bnc-stone-200 dark:border-bnc-stone-800"
    >
      <!-- Cover -->
      <div class="relative w-full overflow-hidden bg-bnc-stone-100 dark:bg-bnc-stone-900" style="max-height: 480px;">
        <Image
          src={data.cover as ImageMetadata}
          alt={`${data.title} cover`}
          width={1280}
          height={640}
          class="w-full object-cover"
          loading="eager"
        />
        <div class="absolute inset-0 bg-gradient-to-t from-bnc-ink/60 to-transparent pointer-events-none" aria-hidden="true"></div>
      </div>

      <!-- Metadata strip -->
      <Container>
        <div class="py-8">
          <!-- Breadcrumb -->
          <nav aria-label="Breadcrumb" class="mb-5">
            <ol class="flex items-center gap-2 font-mono text-xs text-bnc-stone-500 dark:text-bnc-stone-400 flex-wrap">
              <li><a href="/en/" class="hover:text-bnc-accent transition-colors">Home</a></li>
              <li aria-hidden="true">/</li>
              <li><a href="/en/portfolio/" class="hover:text-bnc-accent transition-colors">Portfolio</a></li>
              <li aria-hidden="true">/</li>
              <li class="text-bnc-stone-700 dark:text-bnc-stone-300">{data.title}</li>
            </ol>
          </nav>

          <!-- Bucket tag -->
          <div class="mb-3">
            <Tag variant={bucketVariant}>{bucketLabel}</Tag>
          </div>

          <!-- Project title (h1) -->
          <h1
            id="project-title"
            class="font-display font-semibold text-bnc-ink dark:text-bnc-paper leading-tight mb-4"
            style="font-size: var(--fs-48)"
          >
            {data.title}
          </h1>

          <!-- Metadata strip: client · year · status -->
          <div class="flex flex-wrap items-center gap-4 font-mono text-xs text-bnc-stone-500 dark:text-bnc-stone-400">
            <span>{data.client}</span>
            <span aria-hidden="true">·</span>
            <span>{data.year}</span>
            <span aria-hidden="true">·</span>
            <span
              class:list={[
                'px-2 py-0.5 rounded-[var(--radius-sm)]',
                data.status === 'live' ? 'bg-green-100 text-green-700 dark:bg-green-900/30 dark:text-green-400' : '',
                data.status === 'maintained' ? 'bg-blue-100 text-blue-700 dark:bg-blue-900/30 dark:text-blue-400' : '',
                data.status === 'archived' ? 'bg-bnc-stone-200 text-bnc-stone-600 dark:bg-bnc-stone-800 dark:text-bnc-stone-400' : '',
              ]}
            >
              {statusLabel}
            </span>
          </div>
        </div>
      </Container>
    </section>

    <!-- Summary -->
    <section aria-label="Project summary" style="padding-block: var(--spacing-section-y-sm)">
      <Container>
        <div class="max-w-3xl">
          <p
            class="text-bnc-stone-700 dark:text-bnc-stone-300 leading-relaxed"
            style="font-size: var(--fs-20)"
          >
            {data.summary}
          </p>
        </div>
      </Container>
    </section>

    <!-- Problem / Solution two-col -->
    <section
      aria-labelledby="problem-heading"
      class="border-y border-bnc-stone-200 dark:border-bnc-stone-800 bg-bnc-stone-50 dark:bg-bnc-stone-900"
      style="padding-block: var(--spacing-section-y)"
    >
      <Container>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-12">
          <!-- Problem -->
          <div>
            <p class="font-mono text-xs tracking-widest uppercase text-bnc-stone-500 dark:text-bnc-stone-400 mb-3">
              // Problem
            </p>
            <h2
              id="problem-heading"
              class="font-display font-semibold text-bnc-ink dark:text-bnc-paper leading-snug mb-4"
              style="font-size: var(--fs-28)"
            >
              The Challenge
            </h2>
            <p class="text-bnc-stone-600 dark:text-bnc-stone-400 leading-relaxed" style="font-size: var(--fs-17)">
              {data.problem}
            </p>
          </div>

          <!-- Solution -->
          <div>
            <p class="font-mono text-xs tracking-widest uppercase text-bnc-stone-500 dark:text-bnc-stone-400 mb-3">
              // Solution
            </p>
            <h2
              class="font-display font-semibold text-bnc-ink dark:text-bnc-paper leading-snug mb-4"
              style="font-size: var(--fs-28)"
            >
              What We Built
            </h2>
            <p class="text-bnc-stone-600 dark:text-bnc-stone-400 leading-relaxed" style="font-size: var(--fs-17)">
              {data.solution}
            </p>
          </div>
        </div>
      </Container>
    </section>

    <!-- MDX body (extended narrative + screenshots) -->
    <section aria-label="Project detail" style="padding-block: var(--spacing-section-y)">
      <Container>
        <div style="max-width: var(--prose-max)">
          <Prose>
            <Content />
          </Prose>
        </div>
      </Container>
    </section>

    <!-- Impact -->
    <section
      aria-labelledby="impact-heading"
      class="border-y border-bnc-stone-200 dark:border-bnc-stone-800 bg-bnc-stone-50 dark:bg-bnc-stone-900"
      style="padding-block: var(--spacing-section-y-sm)"
    >
      <Container>
        <div class="max-w-3xl">
          <p class="font-mono text-xs tracking-widest uppercase text-bnc-stone-500 dark:text-bnc-stone-400 mb-3">
            // Impact
          </p>
          <h2
            id="impact-heading"
            class="font-display font-semibold text-bnc-ink dark:text-bnc-paper leading-snug mb-6"
            style="font-size: var(--fs-28)"
          >
            Impact & Results
          </h2>
          <ul class="flex flex-col gap-3">
            {data.impact.map((item) => (
              <li class="flex items-start gap-3">
                <span class="mt-1 shrink-0 w-4 h-4 rounded-full bg-bnc-accent/20 flex items-center justify-center" aria-hidden="true">
                  <span class="w-1.5 h-1.5 rounded-full bg-bnc-accent block"></span>
                </span>
                <span class="text-bnc-stone-700 dark:text-bnc-stone-300 leading-relaxed" style="font-size: var(--fs-17)">
                  {item}
                </span>
              </li>
            ))}
          </ul>
        </div>
      </Container>
    </section>

    <!-- Tech stack -->
    <section aria-label="Tech stack" style="padding-block: var(--spacing-section-y-sm)">
      <Container>
        <p class="font-mono text-xs tracking-widest uppercase text-bnc-stone-500 dark:text-bnc-stone-400 mb-4">
          // Tech Stack
        </p>
        <div class="flex flex-wrap gap-2">
          {data.stack.map((tech) => (
            <Tag variant="default">{tech}</Tag>
          ))}
        </div>
      </Container>
    </section>

    <!-- External links -->
    {data.links && (
      <section aria-label="External links" class="border-t border-bnc-stone-200 dark:border-bnc-stone-800" style="padding-block: var(--spacing-section-y-sm)">
        <Container>
          <p class="font-mono text-xs tracking-widest uppercase text-bnc-stone-500 dark:text-bnc-stone-400 mb-4">
            // Links
          </p>
          <div class="flex flex-wrap gap-3">
            {data.links.playStore && (
              <Button href={data.links.playStore} external variant="secondary" size="md">
                Google Play →
              </Button>
            )}
            {data.links.appStore && (
              <Button href={data.links.appStore} external variant="secondary" size="md">
                App Store →
              </Button>
            )}
            {data.links.web && (
              <Button href={data.links.web} external variant="secondary" size="md">
                Website →
              </Button>
            )}
            {data.links.github && (
              <Button href={data.links.github} external variant="ghost" size="md">
                GitHub →
              </Button>
            )}
          </div>
        </Container>
      </section>
    )}

    <!-- Linked testimonial (conditional) -->
    {linkedTestimonial && (
      <section
        aria-label="Testimonial"
        class="border-y border-bnc-stone-200 dark:border-bnc-stone-800 bg-bnc-stone-50 dark:bg-bnc-stone-900"
        style="padding-block: var(--spacing-section-y-sm)"
      >
        <Container class="max-w-2xl">
          <blockquote class="flex flex-col gap-4">
            <p
              class="text-bnc-stone-700 dark:text-bnc-stone-300 leading-relaxed italic"
              style="font-size: var(--fs-20)"
            >
              "{linkedTestimonial.data.quote}"
            </p>
            <footer class="font-mono text-xs text-bnc-stone-500 dark:text-bnc-stone-400">
              {linkedTestimonial.data.author} · {linkedTestimonial.data.role}, {linkedTestimonial.data.company}
            </footer>
          </blockquote>
        </Container>
      </section>
    )}

    <!-- Next case study -->
    {nextProject && (
      <section aria-label="Next project" style="padding-block: var(--spacing-section-y-sm)">
        <Container>
          <div class="flex items-center justify-between gap-4 flex-wrap">
            <div>
              <p class="font-mono text-xs tracking-widest uppercase text-bnc-stone-500 dark:text-bnc-stone-400 mb-2">
                // Next Project
              </p>
              <p
                class="font-display font-semibold text-bnc-ink dark:text-bnc-paper"
                style="font-size: var(--fs-28)"
              >
                {nextProject.data.title}
              </p>
            </div>
            <Button href={`/en/portfolio/${nextProject.data.slug}/`} variant="primary">
              View Project →
            </Button>
          </div>
        </Container>
      </section>
    )}
  </main>

  <Footer />
</BaseLayout>
