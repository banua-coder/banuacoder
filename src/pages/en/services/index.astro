---
import { Image } from 'astro:assets'
import { getCollection } from 'astro:content'
import BaseLayout from '../../../layouts/BaseLayout.astro'
import Nav from '../../../components/layout/Nav.astro'
import Footer from '../../../components/layout/Footer.astro'
import Container from '../../../components/layout/Container.astro'
import SectionHeader from '../../../components/typography/SectionHeader.astro'
import ServiceCard from '../../../components/cards/ServiceCard.astro'
import Card from '../../../components/atoms/Card.astro'
import CTA from '../../../components/sections/CTA.astro'
import buildImg from '../../../assets/stock/workspace-code-monitor.jpg'
import brandImg from '../../../assets/stock/designer-sketch-tools.jpg'
{/* buildImg — unsplash: https://unsplash.com/photos/black-laptop-computer-1517694712202-14dd9538aa97 */}
{/* brandImg — unsplash: https://unsplash.com/photos/person-holding-pencil-and-stick-note-beside-table-1541462608143-67571c6738dd */}

const allServices = await getCollection('services')
const enServices = allServices
  .filter((s) => s.data.locale === 'en')
  .sort((a, b) => a.data.order - b.data.order)

const byCategory = {
  'customer-facing': enServices.filter((s) => s.data.category === 'customer-facing'),
  'internal-ops': enServices.filter((s) => s.data.category === 'internal-ops'),
  'product-engineering': enServices.filter((s) => s.data.category === 'product-engineering'),
  'design': enServices.filter((s) => s.data.category === 'design'),
  'social-media': enServices.filter((s) => s.data.category === 'social-media'),
}

const engagementModels = [
  {
    title: 'Project-Based',
    tagline: 'Fixed scope, clear timeline, defined price.',
    bullets: [
      'Clearly defined deliverables and milestones',
      'Ideal for websites, apps, or new systems',
      'Works best when requirements are reasonably clear upfront',
    ],
  },
  {
    title: 'Discovery Sprint',
    tagline: 'Validate and define scope in 1–2 weeks.',
    bullets: [
      'Focused sessions to map problem and solution',
      'Produces documented scope ready for build',
      'Reduce risk before committing to full development',
    ],
  },
  {
    title: 'Monthly Retainer',
    tagline: 'Engineering capacity available every month.',
    bullets: [
      'Regular developer or designer without full-time hiring',
      'Suited for product iteration or ongoing marketing work',
      'Flexible to changing needs month to month',
    ],
  },
  {
    title: 'Managed Services',
    tagline: 'Long-term partnership from build to support.',
    bullets: [
      'End-to-end from scoping, delivery, to maintenance',
      'Ideal for organizations without an internal technical team',
      'One partner for all long-term digital needs',
    ],
  },
]
---

<BaseLayout
  title="App & Website Development Services — Banua Coder"
  description="Banua Coder helps businesses build websites, mobile apps, operational systems, brand design, and social media management."
>
  <a
    href="#main-content"
    class="sr-only focus:not-sr-only focus:fixed focus:top-4 focus:left-4 focus:z-[9999] focus:px-4 focus:py-2 focus:bg-bnc-primary focus:text-white focus:rounded-[var(--radius-sm)]"
  >
    Skip to main content
  </a>

  <Nav />

  <main id="main-content">
    <!-- Hero -->
    <section
      aria-labelledby="services-hero-heading"
      class="border-b border-bnc-stone-200 dark:border-bnc-stone-800"
      style="padding-block: var(--spacing-section-y)"
    >
      <Container>
        <p class="font-mono text-xs tracking-widest uppercase text-bnc-stone-500 dark:text-bnc-stone-400 mb-3">
          // SERVICES
        </p>
        <div class="flex items-center gap-3 mb-5">
          <span class="font-mono text-xs tracking-widest text-bnc-accent" aria-hidden="true">[ 01 ]</span>
        </div>
        <h1
          id="services-hero-heading"
          class="font-display font-bold text-bnc-ink dark:text-bnc-paper leading-tight mb-5"
          style="font-size: var(--fs-64)"
        >
          Services
        </h1>
        <p
          class="text-bnc-stone-600 dark:text-bnc-stone-400 leading-relaxed"
          style="font-size: var(--fs-20); max-width: 60ch"
        >
          From customer-facing digital products to internal operational systems, brand design, and social media — Banua Coder helps businesses build relevant, growth-ready solutions.
        </p>
      </Container>
    </section>

    <!-- SUPERCATEGORY 1: Build & Engineer -->
    <section id="build" aria-labelledby="build-heading" style="padding-block: var(--spacing-section-y)">
      <Container>
        <div class="mb-12">
          <p class="font-mono text-xs tracking-widest uppercase text-bnc-accent mb-2">// Build & Engineer</p>
          <h2
            id="build-heading"
            class="font-display font-bold text-bnc-ink dark:text-bnc-paper leading-tight mb-5"
            style="font-size: var(--fs-48)"
          >
            Build & Engineer
          </h2>
          <div class="grid grid-cols-1 lg:grid-cols-2 gap-10 items-start mb-8">
            <div class="flex flex-col gap-4 text-bnc-stone-600 dark:text-bnc-stone-400 leading-relaxed" style="font-size: var(--fs-17)">
              <p>
                Behind every growing business is a digital system that actually works. A website that loads fast. An app that doesn't disappoint users when it matters. A dashboard that gives data visibility without requiring manual reports. These aren't luxuries — they're the operational foundation modern businesses need.
              </p>
              <p>
                Banua Coder builds digital products and systems with genuine engineering discipline: structures built to evolve, code that can be maintained, and delivery that's clear step by step. Our founder brings experience from complex product engineering environments — large-scale fintech, international consumer platforms, and public systems — so those standards of thinking show up in every project we take on, regardless of its size.
              </p>
            </div>
            <div class="overflow-hidden rounded-[var(--radius-md)] border border-bnc-stone-200 dark:border-bnc-stone-800">
              <Image
                src={buildImg}
                alt="Engineer at workstation — Banua Coder engineering approach"
                width={600}
                class="w-full object-cover"
                style="max-height: 260px"
              />
            </div>
          </div>
        </div>

        <!-- Customer-facing -->
        {byCategory['customer-facing'].length > 0 && (
          <div class="mb-14">
            <div class="flex items-center gap-3 mb-2">
              <span class="w-8 h-px bg-bnc-stone-300 dark:bg-bnc-stone-700" aria-hidden="true"></span>
              <h3 class="font-mono text-xs tracking-widest uppercase text-bnc-stone-500 dark:text-bnc-stone-400">
                Customer-Facing Products
              </h3>
            </div>
            <p class="text-bnc-stone-500 dark:text-bnc-stone-400 mb-6" style="font-size: var(--fs-17)">
              Websites, mobile apps, portals, and membership experiences for businesses wanting a more professional digital presence.
            </p>
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
              {byCategory['customer-facing'].map((svc) => (
                <ServiceCard
                  title={svc.data.title}
                  tagline={svc.data.tagline}
                  icon={svc.data.icon}
                  deliverables={svc.data.deliverables}
                  href={`/en/services/${svc.data.slug}/`}
                />
              ))}
            </div>
          </div>
        )}

        <!-- Internal ops -->
        {byCategory['internal-ops'].length > 0 && (
          <div class="mb-14">
            <div class="flex items-center gap-3 mb-2">
              <span class="w-8 h-px bg-bnc-stone-300 dark:bg-bnc-stone-700" aria-hidden="true"></span>
              <h3 class="font-mono text-xs tracking-widest uppercase text-bnc-stone-500 dark:text-bnc-stone-400">
                Internal Operational Systems
              </h3>
            </div>
            <p class="text-bnc-stone-500 dark:text-bnc-stone-400 mb-6" style="font-size: var(--fs-17)">
              Dashboards, admin panels, approval workflows, and internal tools that streamline business operations.
            </p>
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
              {byCategory['internal-ops'].map((svc) => (
                <ServiceCard
                  title={svc.data.title}
                  tagline={svc.data.tagline}
                  icon={svc.data.icon}
                  deliverables={svc.data.deliverables}
                  href={`/en/services/${svc.data.slug}/`}
                />
              ))}
            </div>
          </div>
        )}

        <!-- Product engineering -->
        {byCategory['product-engineering'].length > 0 && (
          <div>
            <div class="flex items-center gap-3 mb-2">
              <span class="w-8 h-px bg-bnc-stone-300 dark:bg-bnc-stone-700" aria-hidden="true"></span>
              <h3 class="font-mono text-xs tracking-widest uppercase text-bnc-stone-500 dark:text-bnc-stone-400">
                Product Engineering & Support
              </h3>
            </div>
            <p class="text-bnc-stone-500 dark:text-bnc-stone-400 mb-6" style="font-size: var(--fs-17)">
              Discovery, MVP, modernization, and long-term engineering support for digital products built to grow.
            </p>
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
              {byCategory['product-engineering'].map((svc) => (
                <ServiceCard
                  title={svc.data.title}
                  tagline={svc.data.tagline}
                  icon={svc.data.icon}
                  deliverables={svc.data.deliverables}
                  href={`/en/services/${svc.data.slug}/`}
                />
              ))}
            </div>
          </div>
        )}
      </Container>
    </section>

    <!-- SUPERCATEGORY 2: Brand & Grow -->
    <section
      id="grow"
      aria-labelledby="grow-heading"
      class="bg-bnc-stone-50 dark:bg-bnc-stone-900 border-y border-bnc-stone-200 dark:border-bnc-stone-800"
      style="padding-block: var(--spacing-section-y)"
    >
      <Container>
        <div class="mb-12">
          <p class="font-mono text-xs tracking-widest uppercase text-bnc-accent mb-2">// Brand & Grow</p>
          <h2
            id="grow-heading"
            class="font-display font-bold text-bnc-ink dark:text-bnc-paper leading-tight mb-5"
            style="font-size: var(--fs-48)"
          >
            Brand & Grow
          </h2>
          <div class="grid grid-cols-1 lg:grid-cols-2 gap-10 items-start mb-8">
            <div class="overflow-hidden rounded-[var(--radius-md)] border border-bnc-stone-200 dark:border-bnc-stone-800 order-2 lg:order-1">
              <Image
                src={brandImg}
                alt="Designer working on brand identity — Banua Coder brand and grow"
                width={600}
                class="w-full object-cover"
                style="max-height: 260px"
              />
            </div>
            <div class="flex flex-col gap-4 text-bnc-stone-600 dark:text-bnc-stone-400 leading-relaxed order-1 lg:order-2" style="font-size: var(--fs-17)">
              <p>
                A great product without a strong brand rarely lasts. For F&B, beauty, and SME businesses, visual and digital presence is the primary entry point for new customers. A careless logo, an inconsistent Instagram feed, or no presence at all — these send the wrong signal before your product has a chance to speak for itself.
              </p>
              <p>
                Banua Coder helps businesses build a strong visual identity and a social media presence that actually works. Not just active posting — but structured, consistent, and aligned with brand character. Our design team combines experience in brand identity, product design, and digital content to ensure every customer touchpoint builds trust.
              </p>
            </div>
          </div>
        </div>

        <!-- Design -->
        {byCategory['design'].length > 0 && (
          <div class="mb-14">
            <div class="flex items-center gap-3 mb-2">
              <span class="w-8 h-px bg-bnc-stone-300 dark:bg-bnc-stone-700" aria-hidden="true"></span>
              <h3 class="font-mono text-xs tracking-widest uppercase text-bnc-stone-500 dark:text-bnc-stone-400">
                Design
              </h3>
            </div>
            <p class="text-bnc-stone-500 dark:text-bnc-stone-400 mb-6" style="font-size: var(--fs-17)">
              UI/UX design, logos, brand identity, and marketing collateral — all with a consistent, purposeful visual approach.
            </p>
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
              {byCategory['design'].map((svc) => (
                <ServiceCard
                  title={svc.data.title}
                  tagline={svc.data.tagline}
                  icon={svc.data.icon}
                  deliverables={svc.data.deliverables}
                  href={`/en/services/${svc.data.slug}/`}
                />
              ))}
            </div>
          </div>
        )}

        <!-- Social media -->
        {byCategory['social-media'].length > 0 && (
          <div>
            <div class="flex items-center gap-3 mb-2">
              <span class="w-8 h-px bg-bnc-stone-300 dark:bg-bnc-stone-700" aria-hidden="true"></span>
              <h3 class="font-mono text-xs tracking-widest uppercase text-bnc-stone-500 dark:text-bnc-stone-400">
                Social Media
              </h3>
            </div>
            <p class="text-bnc-stone-500 dark:text-bnc-stone-400 mb-6" style="font-size: var(--fs-17)">
              Strategy, content, and community management to build a relevant and measurable audience.
            </p>
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
              {byCategory['social-media'].map((svc) => (
                <ServiceCard
                  title={svc.data.title}
                  tagline={svc.data.tagline}
                  icon={svc.data.icon}
                  deliverables={svc.data.deliverables}
                  href={`/en/services/${svc.data.slug}/`}
                />
              ))}
            </div>
          </div>
        )}
      </Container>
    </section>

    <!-- Engagement Models -->
    <section aria-labelledby="engagement-heading" style="padding-block: var(--spacing-section-y)">
      <Container>
        <p class="font-mono text-xs tracking-widest uppercase text-bnc-stone-500 dark:text-bnc-stone-400 mb-2">
          // ENGAGEMENT MODELS
        </p>
        <SectionHeader
          eyebrow=""
          marker="[ 02 ]"
          title="How to work with us"
          description="We adapt the engagement model to your needs and business stage — not one size for all."
          class="mb-12"
        />
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
          {engagementModels.map((model) => (
            <Card padding="lg" class="flex flex-col gap-3">
              <h3
                class="font-display font-semibold text-bnc-ink dark:text-bnc-paper"
                style="font-size: var(--fs-20)"
              >
                {model.title}
              </h3>
              <p class="font-mono text-xs text-bnc-accent">{model.tagline}</p>
              <ul class="list-none m-0 p-0 flex flex-col gap-1.5 flex-1" role="list">
                {model.bullets.map((bullet) => (
                  <li class="flex items-start gap-2 text-sm text-bnc-stone-600 dark:text-bnc-stone-400">
                    <span class="text-bnc-accent mt-0.5 shrink-0" aria-hidden="true">→</span>
                    {bullet}
                  </li>
                ))}
              </ul>
              <a
                href="/en/contact/"
                class="font-mono text-xs text-bnc-stone-500 dark:text-bnc-stone-400 hover:text-bnc-accent transition-colors mt-2 inline-flex items-center gap-1"
              >
                Discuss this engagement →
              </a>
            </Card>
          ))}
        </div>
      </Container>
    </section>

    <!-- CTA -->
    <p class="text-center font-mono text-xs text-bnc-stone-500 dark:text-bnc-stone-400 py-4">
      Not sure about the cost?{' '}
      <a href="/en/estimate/" class="text-bnc-accent hover:underline underline-offset-4">
        Try the estimate calculator →
      </a>
    </p>
    <CTA
      headline="Ready to discuss your needs?"
      sub="Let us map the most realistic solution for your business right now."
      primaryCta="Schedule a Discussion"
      primaryHref="/en/contact/"
      inverted={true}
    />
  </main>

  <Footer />
</BaseLayout>
