---
import { Image } from 'astro:assets'
import { ogUrl } from '../lib/og/url'
import BaseLayout from '../layouts/BaseLayout.astro'
import Nav from '../components/layout/Nav.astro'
import Footer from '../components/layout/Footer.astro'
import Container from '../components/layout/Container.astro'
import FounderExperienceStrip from '../components/founder/FounderExperienceStrip.astro'
import CTA from '../components/sections/CTA.astro'
import iconImage from '../assets/brand/banuacoder-icon.png'
import workImg1 from '../assets/founder/work-product/work-1.png'
import workImg2 from '../assets/founder/work-product/work-2.png'
import workImg3 from '../assets/founder/work-product/work-3.png'
import workImg4 from '../assets/founder/work-product/work-4.png'
import workImg5 from '../assets/founder/work-product/work-5.png'
import workImg6 from '../assets/founder/work-product/work-6.png'
import ambientImg from '../assets/stock/clean-workspace-notebook.jpg'
{/* ambientImg — unsplash: https://unsplash.com/photos/laptop-computer-on-glass-top-table-1547658719-da2b51169166 by @cgower */}

const credibilityBullets = [
  'Latar belakang di software engineering dan pengembangan produk digital',
  'Fokus kuat pada mobile engineering, platform, dan performance',
  'Pengalaman pada sistem bisnis, workflow publik, dan produk digital lintas konteks',
  'Pendekatan praktis yang menghubungkan kebutuhan bisnis dengan eksekusi teknis',
  'Aktif dalam knowledge sharing dan komunitas engineering',
]

const selectedExperience = [
  { company: 'GoTo Financial', context: 'Mobile platform engineering — ekosistem fintech skala besar' },
  { company: 'Reku', context: 'Mobile engineering — aplikasi crypto dan investasi digital' },
  { company: 'Stockbit / Bibit', context: 'Mobile platform — komunitas investasi dan reksa dana' },
  { company: 'Ulearna Technology LTD', context: 'International product collaboration — aplikasi consumer-facing untuk market global' },
  { company: 'Sektor Publik', context: 'Sistem digital publik — aplikasi layanan dan pembayaran daerah' },
]

const engineeringPhilosophy = [
  {
    label: '// system over feature',
    title: 'Sistem di atas fitur',
    desc: 'Fitur yang banyak tidak selalu berarti produk yang baik. Banua Coder membangun dengan mempertimbangkan bagaimana sistem akan berkembang—bukan hanya bagaimana ia bekerja saat peluncuran. Ini berarti keputusan arsitektur yang sadar, bukan sekadar mengikuti permintaan satu per satu.',
  },
  {
    label: '// product thinking',
    title: 'Berpikir tentang produk, bukan hanya kode',
    desc: 'Engineering yang baik tidak dimulai dari "bagaimana cara membuat ini" tetapi dari "apakah ini yang harus dibuat." Kami mendekati setiap proyek dengan pemahaman terhadap tujuan bisnis di baliknya—sehingga keputusan teknis diarahkan oleh outcomes, bukan preferensi teknis semata.',
  },
  {
    label: '// craft and discipline',
    title: 'Craft dan disiplin sebagai standar',
    desc: 'Code review, testing, performance, dan aksesibilitas bukan pilihan tambahan—mereka adalah bagian dari cara kami bekerja secara default. Bukan karena sempurnisme, tetapi karena sistem yang tidak dibangun dengan disiplin ini akan menjadi beban teknis yang mahal di masa depan.',
  },
]

const personSchema = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  '@id': 'https://banuacoder.com/founder/#person',
  name: 'Fajrian Aidil Pratama',
  jobTitle: 'Founder & Director',
  worksFor: {
    '@type': 'Organization',
    '@id': 'https://banuacoder.com/#organization',
    name: 'Banua Coder',
    url: 'https://banuacoder.com',
  },
  url: 'https://banuacoder.com/founder/',
  sameAs: [
    'https://linkedin.com/in/ryanaidilp',
    'https://twitter.com/ryanaidilp_',
    'https://github.com/ryanaidilp',
    'https://youtube.com/@banuacoder',
  ],
  description: 'Software engineer dengan pengalaman di mobile engineering, platform, dan digital product development.',
  knowsAbout: [
    'Mobile Engineering',
    'Flutter',
    'Platform Engineering',
    'Product Development',
    'Digital Systems',
    'Laravel',
    'Public Sector Digitalization',
  ],
  nationality: 'Indonesia',
}

const founderBreadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Beranda', item: 'https://banuacoder.com/' },
    { '@type': 'ListItem', position: 2, name: 'Founder', item: 'https://banuacoder.com/founder/' },
  ],
}
---

<BaseLayout
  title="Fajrian Aidil Pratama — Founder, Banua Coder"
  description="Fajrian Aidil Pratama adalah Founder & Director Banua Coder. Software engineer dengan pengalaman di mobile engineering, platform, dan digital product development."
  ogImage={ogUrl('founder')}
>
  <script is:inline type="application/ld+json" slot="head" set:html={JSON.stringify(personSchema)} />
  <script is:inline type="application/ld+json" slot="head" set:html={JSON.stringify(founderBreadcrumbSchema)} />

  <a
    href="#main-content"
    class="sr-only focus:not-sr-only focus:fixed focus:top-4 focus:left-4 focus:z-[9999] focus:px-4 focus:py-2 focus:bg-bnc-primary focus:text-white focus:rounded-[var(--radius-sm)]"
  >
    Lewati ke konten utama
  </a>

  <Nav />

  <main id="main-content">
    <!-- Hero -->
    <section
      aria-labelledby="founder-hero-heading"
      class="border-b border-bnc-stone-200 dark:border-bnc-stone-800"
      style="padding-block: var(--spacing-section-y)"
    >
      <Container>
        <p class="font-mono text-xs tracking-widest uppercase text-bnc-stone-500 dark:text-bnc-stone-400 mb-3">
          // FOUNDER
        </p>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-12 items-start">
          <!-- Text -->
          <div>
            <p class="font-mono text-xs text-bnc-stone-500 dark:text-bnc-stone-400 tracking-widest uppercase mb-2">
              Founder & Director, Banua Coder
            </p>
            <h1
              id="founder-hero-heading"
              class="font-display font-bold text-bnc-ink dark:text-bnc-paper leading-tight mb-4"
              style="font-size: var(--fs-64)"
            >
              Fajrian Aidil Pratama
            </h1>
            <p
              class="font-semibold text-bnc-stone-700 dark:text-bnc-stone-300 mb-6"
              style="font-size: var(--fs-20)"
            >
              Dipimpin oleh engineer dengan exposure pada product, platform, dan sistem operasional
            </p>
            <div class="flex gap-4 flex-wrap">
              <a
                href="https://linkedin.com/in/ryanaidilp"
                target="_blank"
                rel="noopener noreferrer"
                class="font-mono text-xs text-bnc-stone-500 hover:text-bnc-primary dark:hover:text-bnc-accent transition-colors"
              >
                LinkedIn →
              </a>
              <a
                href="https://twitter.com/ryanaidilp_"
                target="_blank"
                rel="noopener noreferrer"
                class="font-mono text-xs text-bnc-stone-500 hover:text-bnc-primary dark:hover:text-bnc-accent transition-colors"
              >
                X / Twitter →
              </a>
            </div>
          </div>
          <!-- Photo placeholder -->
          <div
            class="flex items-center justify-center rounded-[var(--radius-md)] bg-bnc-stone-100 dark:bg-bnc-stone-800 aspect-[3/4] max-w-xs"
            aria-label="Foto Fajrian Aidil Pratama — akan diganti dengan foto profesional"
          >
            <div class="flex flex-col items-center gap-3">
              <Image
                src={iconImage}
                alt=""
                width={60}
                height={60}
                class="opacity-15"
                aria-hidden="true"
                loading="eager"
                decoding="async"
              />
              <span class="font-mono text-xs text-bnc-stone-400 uppercase tracking-widest text-center px-4">
                // foto founder
              </span>
            </div>
          </div>
        </div>
      </Container>
    </section>

    <!-- About Fajrian — expanded story -->
    <section aria-labelledby="narrative-heading" style="padding-block: var(--spacing-section-y)">
      <Container>
        <div class="grid grid-cols-1 lg:grid-cols-3 gap-12 items-start">
          <div class="lg:col-span-2">
            <h2
              id="narrative-heading"
              class="font-display font-semibold text-bnc-ink dark:text-bnc-paper mb-6"
              style="font-size: var(--fs-28)"
            >
              Tentang Ryan
            </h2>
            <div class="flex flex-col gap-5 text-bnc-stone-600 dark:text-bnc-stone-400 leading-relaxed" style="font-size: var(--fs-17)">
              <p>
                Ryan tumbuh di Sulawesi Tengah dan menghabiskan kariernya sebagai software engineer dengan spesialisasi di mobile engineering, platform, dan digital product development. Sejak awal, ia tertarik pada bagaimana sistem yang besar bekerja dari dalam—bukan sekadar membuat fitur yang diminta, tetapi memahami arsitektur, tradeoff, dan dampak jangka panjang dari setiap keputusan teknis.
              </p>
              <p>
                Perjalanan karier Ryan membawanya ke lingkungan product engineering yang jarang diakses oleh engineer dari daerah: GoTo Financial sebagai ekosistem fintech terbesar di Asia Tenggara, Reku dan Stockbit/Bibit sebagai platform investasi consumer yang melayani jutaan pengguna, hingga kolaborasi internasional bersama Ulearna Technology LTD untuk produk yang menyasar pasar global. Di sisi lain, ia juga mengerjakan sistem digital publik—aplikasi layanan pajak dan retribusi daerah yang membutuhkan tingkat kepercayaan dan kejelasan yang berbeda dari produk consumer biasa.
              </p>
              <p>
                Banua Coder lahir dari keinginan untuk membawa standar engineering dan product thinking itu ke konteks lokal—bisnis dan organisasi di daerah yang membutuhkan partner teknologi yang benar-benar bisa diandalkan, bukan hanya vendor yang bisa ngoding. Ryan mendirikan Banua Coder pada 2019 dengan satu keyakinan: kualitas solusi digital tidak seharusnya bergantung pada di mana bisnis itu berada.
              </p>
              <p>
                Pendekatan Ryan dalam memimpin Banua Coder adalah menggabungkan engineering depth dengan product thinking—dua hal yang seringkali dipisahkan di software house konvensional. Hasilnya adalah tim yang tidak hanya bisa membangun apa yang diminta, tetapi juga membantu klien berpikir lebih jernih tentang apa yang sebenarnya perlu dibangun.
              </p>
            </div>
          </div>
          <aside>
            <div class="overflow-hidden rounded-[var(--radius-md)] border border-bnc-stone-200 dark:border-bnc-stone-800">
              <Image
                src={ambientImg}
                alt="Clean workspace — craft and engineering focus"
                width={400}
                class="w-full object-cover"
                style="max-height: 320px"
                loading="lazy"
                decoding="async"
              />
            </div>
          </aside>
        </div>
      </Container>
    </section>

    <!-- Experience strip -->
    <section
      aria-labelledby="experience-strip-heading"
      class="bg-bnc-stone-50 dark:bg-bnc-stone-900 border-y border-bnc-stone-200 dark:border-bnc-stone-800"
      style="padding-block: var(--spacing-section-y-sm)"
    >
      <Container>
        <h2
          id="experience-strip-heading"
          class="font-mono text-xs tracking-widest uppercase text-bnc-stone-500 dark:text-bnc-stone-400 mb-6"
        >
          // Latar belakang terpilih
        </h2>
        <FounderExperienceStrip />
      </Container>
    </section>

    <!-- Cross-context execution -->
    <section aria-labelledby="cross-context-heading" style="padding-block: var(--spacing-section-y)">
      <Container>
        <div class="max-w-3xl">
          <p class="font-mono text-xs tracking-widest uppercase text-bnc-stone-500 dark:text-bnc-stone-400 mb-3">
            // CROSS-CONTEXT EXECUTION
          </p>
          <h2
            id="cross-context-heading"
            class="font-display font-semibold text-bnc-ink dark:text-bnc-paper mb-6"
            style="font-size: var(--fs-28)"
          >
            Eksekusi lintas konteks
          </h2>
          <div class="flex flex-col gap-5 text-bnc-stone-600 dark:text-bnc-stone-400 leading-relaxed" style="font-size: var(--fs-17)">
            <p>
              Banyak engineer bagus hanya pernah bekerja dalam satu konteks: startup consumer, atau enterprise internal, atau agency. Ketika masalah yang dihadapi berbeda dari yang biasa mereka kerjakan, ada risiko nyata bahwa solusi yang dihasilkan tidak tepat—bukan karena kurang pintar, tetapi karena referensinya terbatas.
            </p>
            <p>
              Ryan membawa pengalaman di tiga konteks yang sangat berbeda: produk consumer yang digunakan jutaan orang dan menuntut performance, reliability, serta UX yang sangat baik; sistem publik yang membutuhkan kepercayaan data, auditability, dan kejelasan alur; dan engineering platform yang memprioritaskan maintainability dan developer experience. Setiap konteks mengajarkan sesuatu yang berbeda tentang tradeoff dan prioritas.
            </p>
            <p>
              Hasilnya adalah pendekatan yang adaptif: kami tidak membawa template solusi yang sama untuk setiap klien. Kami membaca konteksnya—apakah ini produk F&B yang butuh membership system simpel dan cepat jalan, atau sistem workflow pemerintah daerah yang butuh struktur data yang jelas dan audit trail—dan menyesuaikan arsitektur serta pendekatan delivery-nya.
            </p>
          </div>
        </div>
      </Container>
    </section>

    <!-- Engineering philosophy -->
    <section
      aria-labelledby="philosophy-heading"
      class="bg-bnc-stone-50 dark:bg-bnc-stone-900 border-y border-bnc-stone-200 dark:border-bnc-stone-800"
      style="padding-block: var(--spacing-section-y)"
    >
      <Container>
        <p class="font-mono text-xs tracking-widest uppercase text-bnc-stone-500 dark:text-bnc-stone-400 mb-3">
          // ENGINEERING PHILOSOPHY
        </p>
        <h2
          id="philosophy-heading"
          class="font-display font-semibold text-bnc-ink dark:text-bnc-paper mb-10"
          style="font-size: var(--fs-28)"
        >
          Prinsip engineering kami
        </h2>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
          {engineeringPhilosophy.map((principle) => (
            <div class="flex flex-col gap-3">
              <p class="font-mono text-xs text-bnc-accent tracking-wider">{principle.label}</p>
              <h3
                class="font-display font-semibold text-bnc-ink dark:text-bnc-paper"
                style="font-size: var(--fs-17)"
              >
                {principle.title}
              </h3>
              <p class="text-bnc-stone-600 dark:text-bnc-stone-400 text-sm leading-relaxed">
                {principle.desc}
              </p>
            </div>
          ))}
        </div>
      </Container>
    </section>

    <!-- Selected work product (redacted) -->
    <section
      aria-labelledby="work-product-heading"
      style="padding-block: var(--spacing-section-y)"
    >
      <Container>
        <p class="font-mono text-xs tracking-widest uppercase text-bnc-stone-500 dark:text-bnc-stone-400 mb-3">
          // SELECTED WORK PRODUCT
        </p>
        <h2
          id="work-product-heading"
          class="font-display font-semibold text-bnc-ink dark:text-bnc-paper mb-3"
          style="font-size: var(--fs-28)"
        >
          Pengalaman lapangan, redacted
        </h2>
        <p class="text-bnc-stone-600 dark:text-bnc-stone-400 mb-8 max-w-2xl" style="font-size: var(--fs-17)">
          Cuplikan kerja teknis dari pengalaman sebelumnya — termasuk pengembangan produk consumer fintech skala jutaan pengguna. Detail produk dan branding diredact untuk menghormati kerahasiaan.
        </p>
        <div
          class="prior-work-marquee relative overflow-hidden -mx-4 sm:-mx-6 lg:-mx-8"
          aria-roledescription="carousel"
          aria-label="Cuplikan kerja produk sebelumnya"
        >
          <div class="prior-work-track flex items-stretch gap-5 px-4 sm:px-6 lg:px-8 will-change-transform">
            {[
              { src: workImg1, alt: "Side-by-side perbandingan light vs dark mode pada layar discover/market" },
              { src: workImg2, alt: "Tampilan flow detail fitur pada aplikasi consumer fintech" },
              { src: workImg3, alt: "Layar reward/cashback dengan ilustrasi dan elemen brand yang diredact" },
              { src: workImg4, alt: "Detail flow fitur consumer fintech dengan animasi micro" },
              { src: workImg5, alt: "Layar Portfolio P/L dengan grafik annotated dan tooltip" },
              { src: workImg6, alt: "Tampilan rincian aset dengan card list dan tab navigasi" },
            ].map(({ src, alt }) => (
              <div class="prior-work-slide shrink-0 border border-bnc-stone-200 dark:border-bnc-stone-800 rounded-[var(--radius-md)] overflow-hidden bg-bnc-stone-50 dark:bg-bnc-stone-900">
                <Image
                  src={src}
                  alt={alt}
                  width={280}
                  class="block w-full h-auto"
                  loading="lazy"
                  decoding="async"
                />
              </div>
            ))}
          </div>
        </div>
        <p class="font-mono text-xs text-bnc-stone-400 dark:text-bnc-stone-600 mt-4">
          Tidak ditampilkan: nama produk, klien tertentu · Geser untuk melihat semua
        </p>
      </Container>
    </section>

    <!-- Selected experience + credibility bullets -->
    <section
      aria-labelledby="selected-exp-heading"
      class="bg-bnc-stone-50 dark:bg-bnc-stone-900 border-y border-bnc-stone-200 dark:border-bnc-stone-800"
      style="padding-block: var(--spacing-section-y)"
    >
      <Container>
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-12">
          <!-- Experience list -->
          <div>
            <h2
              id="selected-exp-heading"
              class="font-display font-semibold text-bnc-ink dark:text-bnc-paper mb-4"
              style="font-size: var(--fs-28)"
            >
              Pengalaman Terpilih
            </h2>
            <p class="text-bnc-stone-600 dark:text-bnc-stone-400 mb-6 text-sm">
              Mencakup pengalaman dan exposure pada lingkungan seperti GoTo Financial, Reku, Stockbit/Bibit, sistem digital sektor publik, serta kolaborasi produk internasional.
            </p>
            <ul class="list-none m-0 p-0 flex flex-col gap-4" role="list">
              {selectedExperience.map((exp) => (
                <li class="flex gap-4 items-start">
                  <span class="w-8 h-px bg-bnc-accent mt-3 shrink-0" aria-hidden="true"></span>
                  <div>
                    <p class="font-semibold text-bnc-ink dark:text-bnc-paper text-sm">{exp.company}</p>
                    <p class="text-bnc-stone-500 dark:text-bnc-stone-400 text-xs mt-0.5">{exp.context}</p>
                  </div>
                </li>
              ))}
            </ul>
          </div>

          <!-- Credibility bullets -->
          <div>
            <h2
              class="font-display font-semibold text-bnc-ink dark:text-bnc-paper mb-6"
              style="font-size: var(--fs-28)"
            >
              Sorotan Kredibilitas
            </h2>
            <ul class="list-none m-0 p-0 flex flex-col gap-3" role="list">
              {credibilityBullets.map((bullet) => (
                <li class="flex items-start gap-3 text-bnc-stone-600 dark:text-bnc-stone-400" style="font-size: var(--fs-17)">
                  <span class="text-bnc-accent mt-1 shrink-0" aria-hidden="true">→</span>
                  {bullet}
                </li>
              ))}
            </ul>
          </div>
        </div>
      </Container>
    </section>

    <!-- Currently leading -->
    <section
      aria-labelledby="leading-heading"
      style="padding-block: var(--spacing-section-y-sm)"
    >
      <Container>
        <h2
          id="leading-heading"
          class="font-display font-semibold text-bnc-ink dark:text-bnc-paper mb-4"
          style="font-size: var(--fs-28)"
        >
          Saat Ini Memimpin
        </h2>
        <p class="text-bnc-stone-600 dark:text-bnc-stone-400 mb-4" style="font-size: var(--fs-17); max-width: 60ch">
          Ryan memimpin Banua Coder bersama tim yang solid—mencakup engineering, design, dan delivery. Setiap project yang Anda percayakan kepada Banua Coder mendapat perhatian langsung dari Ryan pada tahap discovery dan arsitektur solusi.
        </p>
        <a
          href="/about/"
          class="font-mono text-xs text-bnc-stone-500 hover:text-bnc-accent dark:hover:text-bnc-accent transition-colors inline-flex items-center gap-1.5"
        >
          Kenali seluruh tim →
        </a>
      </Container>
    </section>

    <!-- Connect section -->
    <section
      aria-labelledby="connect-heading"
      class="bg-bnc-stone-50 dark:bg-bnc-stone-900 border-y border-bnc-stone-200 dark:border-bnc-stone-800"
      style="padding-block: var(--spacing-section-y-sm)"
    >
      <Container>
        <p class="font-mono text-xs tracking-widest uppercase text-bnc-stone-500 dark:text-bnc-stone-400 mb-3">
          // CONNECT
        </p>
        <h2
          id="connect-heading"
          class="font-display font-semibold text-bnc-ink dark:text-bnc-paper mb-2"
          style="font-size: var(--fs-20)"
        >
          Ikuti atau terhubung
        </h2>
        <p class="text-bnc-stone-600 dark:text-bnc-stone-400 text-sm mb-6">
          Ryan aktif berbagi tentang engineering, product, dan pengalaman membangun software. Tersedia di platform berikut.
        </p>
        <div class="flex flex-wrap gap-4">
          <a href="https://linkedin.com/in/ryanaidilp" target="_blank" rel="noopener noreferrer" class="font-mono text-xs text-bnc-stone-600 dark:text-bnc-stone-400 hover:text-bnc-accent transition-colors">
            LinkedIn →
          </a>
          <a href="https://github.com/ryanaidilp" target="_blank" rel="noopener noreferrer" class="font-mono text-xs text-bnc-stone-600 dark:text-bnc-stone-400 hover:text-bnc-accent transition-colors">
            GitHub →
          </a>
          <a href="https://twitter.com/ryanaidilp_" target="_blank" rel="noopener noreferrer" class="font-mono text-xs text-bnc-stone-600 dark:text-bnc-stone-400 hover:text-bnc-accent transition-colors">
            X / Twitter →
          </a>
        </div>
      </Container>
    </section>

    <!-- CTA -->
    <CTA
      headline="Jadwalkan percakapan"
      sub="Diskusikan langsung kebutuhan Anda dengan Ryan dan tim Banua Coder."
      primaryCta="Mulai Diskusi"
      primaryHref="/contact/"
      inverted={true}
    />
  </main>

  <Footer />
</BaseLayout>

<style>
  /* Prior-work marquee — auto-scrolling horizontal carousel of redacted
     screenshots from prior consumer fintech work. Auto-scroll loops on
     a 40s cycle; pauses on hover (desktop) or focus-within (keyboard).
     Track is duplicated in CSS to create a seamless infinite loop. */
  .prior-work-marquee {
    mask-image: linear-gradient(to right, transparent 0, black 6%, black 94%, transparent 100%);
    -webkit-mask-image: linear-gradient(to right, transparent 0, black 6%, black 94%, transparent 100%);
  }
  .prior-work-track {
    animation: prior-work-scroll 60s linear infinite;
  }
  .prior-work-marquee:hover .prior-work-track,
  .prior-work-marquee:focus-within .prior-work-track {
    animation-play-state: paused;
  }
  .prior-work-slide {
    width: clamp(180px, 24vw, 280px);
  }
  .prior-work-slide :global(img) {
    height: auto;
    object-fit: cover;
    aspect-ratio: auto;
  }
  @keyframes prior-work-scroll {
    from { transform: translateX(0); }
    to   { transform: translateX(-50%); }
  }
  @media (prefers-reduced-motion: reduce) {
    .prior-work-track {
      animation: none;
      flex-wrap: wrap;
      justify-content: center;
    }
    .prior-work-marquee {
      mask-image: none;
      -webkit-mask-image: none;
      overflow: visible;
    }
  }
</style>

<script>
  /* Duplicate the track contents so the CSS keyframe (-50% translate) can
     loop seamlessly. Without duplication you'd see the row snap back at
     the loop boundary. */
  document.querySelectorAll<HTMLElement>('.prior-work-track').forEach((track) => {
    track.innerHTML += track.innerHTML
    track.setAttribute('aria-hidden', 'false')
  })
</script>
