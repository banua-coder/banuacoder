---
/**
 * Container — max-width wrapper with horizontal padding.
 * Used by every section to constrain content to the 1280px grid.
 */
interface Props {
  class?: string
}

const { class: cls = '' } = Astro.props
---

<div
  class:list={['mx-auto w-full px-4 sm:px-6 lg:px-8', cls]}
  style="max-width: var(--container-max)"
>
  <slot />
</div>
