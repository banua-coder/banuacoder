---
/**
 * Logo — renders the Banua Coder brand mark in horizontal, icon, vertical, or app-icon variant.
 *
 * - horizontal / vertical: PNG asset pair, CSS-toggled by html.dark class
 * - icon: inline SVG using currentColor, theme-aware via CSS variable
 *   (deep blue in light mode, paper in dark mode)
 * - app-icon: static blue-plate SVG (theme-independent, e.g. for OG images)
 */
import { Image } from 'astro:assets'
import horizontalLight from '../../assets/brand/banuacoder-horizontal.png'
import horizontalDark from '../../assets/brand/banuacoder-horizontal-dark.png'
import verticalLight from '../../assets/brand/banuacoder-vertical.png'
import verticalDark from '../../assets/brand/banuacoder-vertical-dark.png'
import appIconUrl from '../../assets/brand/svg/banuacoder-app-icon.svg?url'

interface Props {
  /** Which logo asset to render */
  variant?: 'horizontal' | 'icon' | 'vertical' | 'app-icon'
  /** Pixel width override — defaults per variant */
  width?: number
  /** Alt text override */
  alt?: string
  /** Extra CSS classes */
  class?: string
}

const {
  variant = 'horizontal',
  width,
  alt = 'Banua Coder',
  class: cls = '',
} = Astro.props

const defaultWidths: Record<string, number> = {
  horizontal: 180,
  icon: 40,
  vertical: 120,
  'app-icon': 48,
}
const resolvedWidth = width ?? defaultWidths[variant]

const isHorizontalOrVertical = variant === 'horizontal' || variant === 'vertical'
const lightAsset = variant === 'horizontal' ? horizontalLight : verticalLight
const darkAsset = variant === 'horizontal' ? horizontalDark : verticalDark
const resolvedHeight = isHorizontalOrVertical
  ? Math.round(resolvedWidth * (lightAsset.height / lightAsset.width))
  : resolvedWidth
---

{variant === 'icon' ? (
  <span class:list={['bnc-logo-icon', cls]} style={`display:inline-block;width:${resolvedWidth}px;line-height:0`} aria-label={alt} role="img">
    <svg xmlns="http://www.w3.org/2000/svg" viewBox="193 745 165 130" fill="none" fill-rule="evenodd" style="display:block;width:100%;height:auto" aria-hidden="true">
      <path d="M246.91,763.974l6.66,6.661c-10.99,8.825 -18.115,22.954 -18.115,38.867c0,15.912 7.125,30.042 18.115,38.867l-6.66,6.66c-12.681,-10.582 -20.835,-27.047 -20.835,-45.527c-0,-18.48 8.154,-34.946 20.835,-45.528Z" fill="#1d9cd4"/>
      <path d="M259.8,863.013c-4.628,2.713 -10.015,4.269 -15.762,4.269l-47.601,-0l-0,-40.616c-0,-6.885 -5.59,-12.474 -12.475,-12.474c0,0 0,-9.38 0,-9.38c6.885,-0 12.475,-5.59 12.475,-12.475l-0,-40.615l47.601,-0l0.101,0c5.71,0.019 11.061,1.572 15.66,4.268c6.314,-2.751 13.224,-4.268 20.463,-4.268c18.578,-0 34.985,9.991 44.75,25.205l-6.817,6.817c-7.937,-13.6 -21.965,-22.642 -37.933,-22.642c-4.248,0 -8.36,0.641 -12.255,1.836c4.535,5.422 7.266,12.404 7.266,20.019c-0,11.2 -5.908,21.031 -14.775,26.545c8.867,5.513 14.775,15.344 14.775,26.545c-0,7.614 -2.731,14.596 -7.266,20.018c3.896,1.196 8.007,1.836 12.255,1.836c18.318,0 34.082,-11.898 41.028,-28.927l7.096,7.096c-9.027,18.536 -27.198,31.212 -48.124,31.212c-7.239,-0 -14.149,-1.517 -20.462,-4.269Zm-53.983,-5.112l0,-31.235c0,-6.958 -3.259,-13.162 -8.332,-17.164c5.073,-4.003 8.332,-10.206 8.332,-17.165l0,-31.235l38.221,0c12.062,0 21.854,9.793 21.854,21.855c0,12.062 -9.792,21.855 -21.854,21.855l-0,9.38c12.062,0 21.854,9.793 21.854,21.855c0,12.037 -9.753,21.815 -21.784,21.854l-0.07,0l-38.221,0Z" fill="currentColor"/>
    </svg>
  </span>
) : variant === 'app-icon' ? (
  <img
    src={appIconUrl}
    alt={alt}
    width={resolvedWidth}
    class:list={[cls]}
    loading="eager"
    decoding="async"
  />
) : (
  <span class:list={['bnc-logo-swap', cls]} style={`display:inline-block;width:${resolvedWidth}px;height:${resolvedHeight}px`}>
    <Image
      src={lightAsset}
      alt={alt}
      width={resolvedWidth}
      height={resolvedHeight}
      class="bnc-logo-light"
      loading="eager"
      decoding="async"
    />
    <Image
      src={darkAsset}
      alt={alt}
      width={resolvedWidth}
      height={resolvedHeight}
      class="bnc-logo-dark"
      loading="eager"
      decoding="async"
      aria-hidden="true"
    />
  </span>
)}

<style>
  /* Icon variant: B+C use currentColor; we set color via CSS variable per theme */
  .bnc-logo-icon {
    color: var(--color-bnc-primary);
  }
  :global(html.dark) .bnc-logo-icon {
    color: var(--color-bnc-paper);
  }

  /* Horizontal / vertical: stacked PNGs, opacity-toggled */
  .bnc-logo-swap {
    position: relative;
    line-height: 0;
  }
  .bnc-logo-swap :global(.bnc-logo-light),
  .bnc-logo-swap :global(.bnc-logo-dark) {
    display: block;
    width: 100%;
    height: 100%;
  }
  .bnc-logo-swap :global(.bnc-logo-dark) {
    position: absolute;
    inset: 0;
    opacity: 0;
  }
  :global(html.dark) .bnc-logo-swap :global(.bnc-logo-light) {
    opacity: 0;
  }
  :global(html.dark) .bnc-logo-swap :global(.bnc-logo-dark) {
    opacity: 1;
  }
</style>
