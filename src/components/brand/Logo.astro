---
/**
 * Logo — renders the Banua Coder brand mark from clean extracted SVG variants.
 * Light/dark variants swap automatically based on the active theme (html.dark class).
 *
 * NOTE: The original PNG assets in src/assets/brand/ are retained as fallbacks;
 * this component now sources all variants from src/assets/brand/svg/.
 * The PNG files can be removed in a future cleanup once all usage is confirmed.
 */

interface Props {
  /** Which logo asset to render */
  variant?: 'horizontal' | 'icon' | 'vertical' | 'app-icon'
  /** Pixel width override — defaults per variant */
  width?: number
  /** Alt text override */
  alt?: string
  /**
   * Override theme adaptation.
   * - 'auto' (default): CSS-toggles light/dark SVG based on html.dark class
   * - 'light': always render the light variant
   * - 'dark': always render the dark variant
   */
  theme?: 'auto' | 'light' | 'dark'
  /** Extra CSS classes */
  class?: string
}

const {
  variant = 'horizontal',
  width,
  alt = 'Banua Coder',
  theme = 'auto',
  class: cls = '',
} = Astro.props

const defaultWidths: Record<string, number> = {
  horizontal: 180,
  icon: 40,
  vertical: 120,
  'app-icon': 48,
}
const resolvedWidth = width ?? defaultWidths[variant]

// app-icon is always the same regardless of theme
const isAppIcon = variant === 'app-icon'

// Map variant → SVG file paths (relative to /public — or use absolute import paths as strings)
// We use direct /src/assets/brand/svg/ paths via ?url imports for Astro asset handling.
// For SVGs used as <img src>, we can reference them as static paths from /public if copied,
// but the simpler approach is to import them as ?url so Astro processes them correctly.
import horizontalLightUrl from '../../assets/brand/svg/banuacoder-horizontal-light.svg?url'
import horizontalDarkUrl from '../../assets/brand/svg/banuacoder-horizontal-dark.svg?url'
import verticalLightUrl from '../../assets/brand/svg/banuacoder-vertical-light.svg?url'
import verticalDarkUrl from '../../assets/brand/svg/banuacoder-vertical-dark.svg?url'
import iconUrl from '../../assets/brand/svg/banuacoder-icon.svg?url'
import appIconUrl from '../../assets/brand/svg/banuacoder-app-icon.svg?url'

const lightSrc: Record<string, string> = {
  horizontal: horizontalLightUrl,
  icon: iconUrl,
  vertical: verticalLightUrl,
  'app-icon': appIconUrl,
}

const darkSrc: Record<string, string> = {
  horizontal: horizontalDarkUrl,
  icon: iconUrl,
  vertical: verticalDarkUrl,
  'app-icon': appIconUrl,
}

// When theme is forced, use dark src; otherwise use light src (auto-swap handled by CSS)
const showDark = theme === 'dark'
---

{isAppIcon || theme !== 'auto' ? (
  <!-- Single static image (app-icon, or forced light/dark) -->
  <img
    src={showDark ? darkSrc[variant] : lightSrc[variant]}
    alt={alt}
    width={resolvedWidth}
    class:list={[cls]}
    loading="eager"
    decoding="async"
  />
) : (
  <!-- Auto: both variants, CSS-toggled -->
  <span class:list={['bnc-logo-swap', cls]} style={`display:inline-block;width:${resolvedWidth}px`}>
    <img
      src={lightSrc[variant]}
      alt={alt}
      width={resolvedWidth}
      class="bnc-logo-light"
      loading="eager"
      decoding="async"
    />
    <img
      src={darkSrc[variant]}
      alt={alt}
      width={resolvedWidth}
      class="bnc-logo-dark"
      loading="eager"
      decoding="async"
      aria-hidden="true"
    />
  </span>
)}

<style>
  .bnc-logo-swap {
    position: relative;
    line-height: 0;
  }
  .bnc-logo-swap .bnc-logo-light,
  .bnc-logo-swap .bnc-logo-dark {
    display: block;
    width: 100%;
    height: auto;
  }
  .bnc-logo-swap .bnc-logo-dark {
    position: absolute;
    inset: 0;
    opacity: 0;
  }
  :global(html.dark) .bnc-logo-swap .bnc-logo-light {
    opacity: 0;
  }
  :global(html.dark) .bnc-logo-swap .bnc-logo-dark {
    opacity: 1;
  }
</style>
