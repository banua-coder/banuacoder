---
/**
 * ClientLogoCycle — pinned scroll-driven client logo reveal (ZOG-style).
 *
 * Section is h-[300vh]; inner panel is sticky top-0 h-screen.
 * A centered headline stays pinned while ~12 logo slots cycle through
 * INDIVIDUAL scroll-triggered enter/exit windows (no batch sync).
 *
 * Each slot has its own scattered position around the viewport edges,
 * its own scroll-progress window, and a unique randomized rotation seed.
 * Multiple slots overlap in time so logos are continuously fading
 * in and out as the user scrubs.
 *
 * GSAP timelines live in src/lib/animations.ts (`.client-cycle` selector,
 * reads data-cell-* attrs on each `.client-cycle-cell`).
 *
 * Reduced-motion fallback: CSS overrides collapse to a static wrap-grid.
 */

import { clients } from '../../data/clients'

const logoModules = import.meta.glob('/src/assets/clients/*.{svg,png}', {
  eager: true,
  query: '?url',
  import: 'default',
}) as Record<string, string>

const logoUrls: Record<string, string> = Object.fromEntries(
  Object.entries(logoModules).map(([path, url]) => [path.split('/').pop() ?? '', url]),
)

interface Props {
  /** Language variant for eyebrow / headline copy */
  lang?: 'id' | 'en'
}

const { lang = 'id' } = Astro.props

const eyebrow = lang === 'en' ? '// TRUSTED BY' : '// DIPERCAYA OLEH'
const heading = lang === 'en' ? 'Our clients and partners' : 'Klien dan partner kami'
const subhead =
  lang === 'en'
    ? 'From public sector to international consumer products.'
    : 'Dari sektor publik hingga produk consumer internasional.'

const byLogo = Object.fromEntries(clients.map((c) => [c.logo, c]))

/**
 * 13 slots scattered around the viewport edges. Center 25–75% × 28–68%
 * is kept clear for the pinned headline.
 *
 * Each slot defines:
 *   - logoFile : which client emblem to render
 *   - fromX/Y  : percent coords where the logo APPEARS (small + blurred)
 *   - toX/Y    : percent coords where the logo DRIFTS to as it fades away
 *                (animations.ts tweens left/top from from→to across the cell's
 *                full lifespan, matching ZOG's parallax-drift effect)
 *   - enter    : scroll progress (0–1) when this cell starts fading IN
 *   - exit     : scroll progress when it starts fading OUT (omit for slots
 *                that should remain visible until the section ends)
 *
 * Stagger of ~0.06 with enter/exit windows of 0.22 keeps 5–6 logos visible
 * mid-transition at any moment. Drifts are subtle (±5–12%) so logos move
 * in a parallax direction during their lifespan rather than just blipping.
 */
type Slot = {
  logoFile: string
  fromX: number
  fromY: number
  toX: number
  toY: number
  enter: number
  exit?: number
}

const slots: Slot[] = [
  // top-left → drifts further NW
  { logoFile: 'ulearna.png',            fromX: 15, fromY: 18, toX:  5, toY: 13, enter: 0.00, exit: 0.30 },
  // top-right → drifts NE
  { logoFile: 'pemprov-sulteng.svg',    fromX: 85, fromY: 22, toX: 95, toY: 17, enter: 0.06, exit: 0.36 },
  // bottom-left → drifts SW
  { logoFile: 'brantas-inti-utama.png', fromX: 10, fromY: 78, toX:  3, toY: 88, enter: 0.12, exit: 0.42 },
  // bottom-right → drifts SE
  { logoFile: 'pemkab-gowa.png',        fromX: 88, fromY: 82, toX: 96, toY: 92, enter: 0.18, exit: 0.48 },
  // top-mid-left → drifts up + left
  { logoFile: 'pemprov-sulsel.svg',     fromX: 42, fromY: 10, toX: 32, toY:  6, enter: 0.24, exit: 0.54 },
  // bottom-mid-right → drifts down + right
  { logoFile: 'klinikgo.png',           fromX: 58, fromY: 88, toX: 70, toY: 94, enter: 0.30, exit: 0.60 },
  // mid-far-left → drifts further off-screen left
  { logoFile: 'pemkab-donggala.png',    fromX:  8, fromY: 48, toX: -2, toY: 53, enter: 0.36, exit: 0.66 },
  // mid-far-right → drifts further right
  { logoFile: 'ulearna.png',            fromX: 92, fromY: 52, toX: 102, toY: 47, enter: 0.42, exit: 0.72 },
  // top-right-2 → drifts NE
  { logoFile: 'brantas-inti-utama.png', fromX: 72, fromY: 14, toX: 82, toY: 10, enter: 0.48, exit: 0.78 },
  // bottom-left-2 → drifts SW
  { logoFile: 'pemkab-donggala.png',    fromX: 28, fromY: 86, toX: 18, toY: 92, enter: 0.54, exit: 0.84 },
  // bottom-right-2 → drifts SE (no exit, anchors the end)
  { logoFile: 'pemprov-sulteng.svg',    fromX: 78, fromY: 78, toX: 86, toY: 86, enter: 0.60 },
  // top-left-2 → drifts NW
  { logoFile: 'klinikgo.png',           fromX: 22, fromY: 18, toX: 14, toY: 13, enter: 0.66 },
  // bottom-mid → drifts down + slight right
  { logoFile: 'pemprov-sulsel.svg',     fromX: 50, fromY: 88, toX: 56, toY: 94, enter: 0.72 },
]
---

<section
  class="client-cycle relative h-[300vh]"
  aria-label={lang === 'en' ? 'Clients and partners' : 'Klien dan partner kami'}
>
  <div class="client-cycle-pin sticky top-0 h-screen flex items-center justify-center isolate overflow-hidden">
    <!-- Centered headline + subhead — pinned while logos cycle -->
    <div class="relative z-10 text-center px-4 pointer-events-none select-none">
      <p class="font-mono text-xs uppercase tracking-widest text-bnc-stone-500 dark:text-bnc-stone-400">
        {eyebrow}
      </p>
      <h2
        class="font-display font-semibold text-bnc-ink dark:text-bnc-paper mt-3 leading-tight"
        style="font-size: var(--fs-48)"
      >
        {heading}
      </h2>
      <p class="text-bnc-stone-600 dark:text-bnc-stone-400 max-w-xl mx-auto mt-4" style="font-size: var(--fs-17)">
        {subhead}
      </p>
    </div>

    <!-- Scattered absolute-positioned logo cells. Each one animates independently. -->
    <div class="client-cycle-stage absolute inset-0 pointer-events-none" aria-hidden="true">
      {slots.map((slot, idx) => {
        const client = byLogo[slot.logoFile]
        if (!client) return null
        const logoUrl = logoUrls[slot.logoFile]
        return (
          <div
            class="client-cycle-cell absolute"
            style={`left: ${slot.fromX}%; top: ${slot.fromY}%; transform: translate(-50%, -50%);`}
            data-cell-index={idx}
            data-cell-from-x={slot.fromX}
            data-cell-from-y={slot.fromY}
            data-cell-to-x={slot.toX}
            data-cell-to-y={slot.toY}
            data-cell-enter={slot.enter}
            data-cell-exit={slot.exit ?? ''}
          >
            <div class="flex items-center justify-center px-5 py-4 rounded-[var(--radius-md)] border border-bnc-stone-200/70 dark:border-bnc-stone-800/70 bg-bnc-paper/95 dark:bg-bnc-stone-900/95 shadow-sm backdrop-blur-sm">
              {logoUrl ? (
                <img
                  src={logoUrl}
                  alt={client.name}
                  loading="lazy"
                  decoding="async"
                  class="h-12 sm:h-14 w-auto max-w-[140px] object-contain"
                />
              ) : (
                <span class="font-mono text-sm font-medium uppercase tracking-wider text-bnc-stone-700 dark:text-bnc-stone-300 whitespace-nowrap">
                  {client.name}
                </span>
              )}
            </div>
          </div>
        )
      })}
    </div>
  </div>
</section>

<style>
  /* Reduced-motion: collapse the 300vh scroll space and show all logos
     statically as a centered wrap row beneath the headline. */
  @media (prefers-reduced-motion: reduce) {
    .client-cycle {
      height: auto;
    }
    .client-cycle-pin {
      position: static;
      height: auto;
      flex-direction: column;
      gap: 2rem;
      padding-block: var(--spacing-section-y-sm);
    }
    .client-cycle-stage {
      position: static;
      display: flex;
      flex-wrap: wrap;
      justify-content: center;
      gap: 1rem;
      width: 100%;
      max-width: 720px;
    }
    .client-cycle-cell {
      position: static !important;
      transform: none !important;
      filter: none !important;
      opacity: 1 !important;
      visibility: visible !important;
    }
  }
</style>
