// ─── Show output ──────────────────────────────────────────────────────────
function showOutput(s: WizardState): void {
  const out = calculate(s as EstimatorInput)
  const outputEl = getEl('estimator-output')
  if (!outputEl) return

  outputEl.textContent = ''
  outputEl.appendChild(buildOutputEl(s, out))
  outputEl.classList.remove('hidden')
  outputEl.scrollIntoView({ behavior: 'smooth', block: 'start' })

  getEl('btn-recalculate')?.addEventListener('click', () => {
    outputEl.classList.add('hidden')
    outputEl.textContent = ''
    setState(defaultState())
  })
}

// ─── State management ─────────────────────────────────────────────────────
let state: WizardState = hashToState()

function setState(newState: WizardState, pushHash = true): void {
  state = newState
  if (pushHash) history.replaceState(null, '', stateToHash(state))
  renderStep(state)
}

// ─── Event wiring ─────────────────────────────────────────────────────────
document.querySelectorAll<HTMLElement>('.wizard-option').forEach((opt) => {
  opt.addEventListener('click', () => {
    setState(handleOptionSelect(opt, state))
  })

  opt.addEventListener('keydown', (e: KeyboardEvent) => {
    if (e.key === ' ' || e.key === 'Enter') {
      e.preventDefault()
      setState(handleOptionSelect(opt, state))
    } else if (e.key === 'ArrowDown' || e.key === 'ArrowRight') {
      e.preventDefault()
      const siblings = Array.from(
        document.querySelectorAll<HTMLElement>(`[data-step="${opt.dataset.step}"].wizard-option`),
      )
      const next = siblings[(siblings.indexOf(opt) + 1) % siblings.length]
      next?.focus()
    } else if (e.key === 'ArrowUp' || e.key === 'ArrowLeft') {
      e.preventDefault()
      const siblings = Array.from(
        document.querySelectorAll<HTMLElement>(`[data-step="${opt.dataset.step}"].wizard-option`),
      )
      const prev = siblings[(siblings.indexOf(opt) - 1 + siblings.length) % siblings.length]
      prev?.focus()
    }
  })
})

getEl('btn-next')?.addEventListener('click', () => {
  if (!isStepValid(state)) return
  if (state.step === TOTAL_STEPS) {
    showOutput(state)
  } else {
    setState(advance(state))
  }
})

getEl('btn-back')?.addEventListener('click', () => {
  setState(goBack(state))
})

document.addEventListener('keydown', (e: KeyboardEvent) => {
  const outputEl = getEl('estimator-output')
  if (!outputEl?.classList.contains('hidden')) return
  if (e.key === 'Escape' && state.step > 1) setState(goBack(state))
})

window.addEventListener('hashchange', () => {
  state = hashToState()
  renderStep(state)
})

// ─── Initial render ───────────────────────────────────────────────────────
renderStep(state)

// Restore output if hash contains a complete state
if (state.type && state.scale && state.users && state.design && state.urgency && state.maintenance) {
  showOutput(state)
}
</script>
