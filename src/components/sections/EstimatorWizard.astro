const isEn = locale === 'en'

function getEl(id: string): HTMLElement | null {
  return document.getElementById(id)
}

function stepEl(n: number): HTMLElement | null {
  return getEl(`step-${n}`)
}

const stepNames = isEn
  ? ['Project Type', 'Scale', 'Users', 'Features', 'Design', 'Timeline', 'Maintenance']
  : ['Tipe Proyek', 'Skala', 'Pengguna', 'Fitur', 'Desain', 'Timeline', 'Maintenance']

