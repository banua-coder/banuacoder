---
/**
 * EstimatorWizard — 7-step project cost estimator.
 * Vanilla TypeScript, no framework islands.
 * State persisted in URL hash. Keyboard navigable.
 * innerHTML usage is safe: all injected content is generated from our own
 * calculate() function, static string constants, and trusted portfolio data
 * injected at build time. No raw user text is ever inserted as HTML.
 */
interface Props {
  locale?: 'id' | 'en'
  portfolioJson?: string
}

const { locale = 'id', portfolioJson = '{}' } = Astro.props
const isEn = locale === 'en'

const steps = isEn
  ? ['Project Type', 'Scale', 'Users', 'Features', 'Design', 'Timeline', 'Maintenance']
  : ['Tipe Proyek', 'Skala', 'Pengguna', 'Fitur', 'Desain', 'Timeline', 'Maintenance']
---

<!-- ══════════════════════════════════════════════════════
     WIZARD SHELL
══════════════════════════════════════════════════════ -->
<div id="estimator-root" data-locale={locale}>

  <!-- Portfolio data injected at build-time for TS to reference client-side -->
  <div id="portfolio-data" data-json={portfolioJson} class="hidden" aria-hidden="true"></div>

  <!-- Progress bar -->
  <div
    class="mb-8"
    role="progressbar"
    aria-valuemin={1}
    aria-valuemax={7}
    aria-valuenow={1}
    aria-label={isEn ? 'Wizard progress' : 'Progres wizard'}
    id="wizard-progress-bar-wrapper"
  >
    <div class="flex items-center justify-between mb-3">
      <span
        class="font-mono text-xs text-bnc-stone-500 dark:text-bnc-stone-400 tracking-widest uppercase"
        id="step-label"
      >
        {isEn ? 'Step 1 of 7' : 'Langkah 1 dari 7'}
      </span>
      <span class="font-mono text-xs text-bnc-accent" id="step-name">{steps[0]}</span>
    </div>
    <div class="w-full h-1 bg-bnc-stone-200 dark:bg-bnc-stone-800 rounded-full overflow-hidden">
      <div
        id="progress-fill"
        class="h-full bg-bnc-accent rounded-full transition-all duration-[var(--duration-base)]"
        style="width: 14.28%"
      ></div>
    </div>
    <div class="flex justify-between mt-2" aria-hidden="true">
      {Array.from({ length: 7 }, (_, i) => (
        <div
          class="w-2 h-2 rounded-full transition-colors duration-[var(--duration-base)] bg-bnc-stone-300 dark:bg-bnc-stone-700"
          data-dot={i + 1}
        ></div>
      ))}
    </div>
  </div>

  <!-- ── Step 1: Project type ──────────────────────────────── -->
  <div id="step-1" class="wizard-step" role="group" aria-labelledby="step1-legend">
    <p id="step1-legend" class="font-display font-semibold text-bnc-ink dark:text-bnc-paper mb-6" style="font-size: var(--fs-28)">
      {isEn ? 'What type of project do you need?' : 'Apa tipe proyek yang Anda butuhkan?'}
    </p>
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
      {[
        { value: 'mobile-app', icon: '📱', label: isEn ? 'Mobile App' : 'Aplikasi Mobile', desc: isEn ? 'iOS and/or Android, native or cross-platform.' : 'iOS dan/atau Android, native atau lintas platform.' },
        { value: 'web-dashboard', icon: '📊', label: isEn ? 'Web Dashboard' : 'Web Dashboard', desc: isEn ? 'Admin panel, analytics, or data-management UI.' : 'Panel admin, analitik, atau manajemen data.' },
        { value: 'website', icon: '🌐', label: isEn ? 'Website' : 'Website', desc: isEn ? 'Company profile, landing page, or content site.' : 'Profil perusahaan, landing page, atau situs konten.' },
        { value: 'internal-system', icon: '⚙️', label: isEn ? 'Internal System' : 'Sistem Internal', desc: isEn ? 'ERP, HRIS, inventory, or operational tools.' : 'ERP, HRIS, inventori, atau alat operasional.' },
        { value: 'hybrid', icon: '🔀', label: 'Hybrid', desc: isEn ? 'Mobile app + web + backend in one engagement.' : 'Aplikasi mobile + web + backend dalam satu proyek.' },
      ].map(opt => (
        <label class="wizard-option" data-step="1" data-value={opt.value} tabindex="0">
          <input type="radio" name="type" value={opt.value} class="sr-only" />
          <span class="option-icon" aria-hidden="true">{opt.icon}</span>
          <span class="option-body">
            <span class="option-label">{opt.label}</span>
            <span class="option-desc">{opt.desc}</span>
          </span>
          <span class="option-check" aria-hidden="true">
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><circle cx="8" cy="8" r="7" stroke="currentColor" stroke-width="1.5"/><path d="M5 8l2 2 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </span>
        </label>
      ))}
    </div>
  </div>

  <!-- ── Step 2: Scale ─────────────────────────────────────── -->
  <div id="step-2" class="wizard-step hidden" role="group" aria-labelledby="step2-legend">
    <p id="step2-legend" class="font-display font-semibold text-bnc-ink dark:text-bnc-paper mb-6" style="font-size: var(--fs-28)">
      {isEn ? 'What scale are you aiming for?' : 'Skala apa yang Anda targetkan?'}
    </p>
    <div class="grid grid-cols-1 gap-3">
      {[
        { value: 'mvp', icon: '🚀', label: 'MVP', desc: isEn ? 'Core user journey only. Launch fast, learn fast.' : 'Hanya perjalanan pengguna utama. Rilis cepat, belajar cepat.' },
        { value: 'standard', icon: '⚡', label: 'Standard', desc: isEn ? 'Full feature set, production-ready, polished UX.' : 'Fitur lengkap, siap produksi, UX yang halus.' },
        { value: 'platform', icon: '🏗️', label: 'Platform', desc: isEn ? 'Multi-tenant, high scalability, extensible architecture.' : 'Multi-tenant, skalabilitas tinggi, arsitektur yang dapat dikembangkan.' },
      ].map(opt => (
        <label class="wizard-option" data-step="2" data-value={opt.value} tabindex="0">
          <input type="radio" name="scale" value={opt.value} class="sr-only" />
          <span class="option-icon" aria-hidden="true">{opt.icon}</span>
          <span class="option-body">
            <span class="option-label">{opt.label}</span>
            <span class="option-desc">{opt.desc}</span>
          </span>
          <span class="option-check" aria-hidden="true">
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><circle cx="8" cy="8" r="7" stroke="currentColor" stroke-width="1.5"/><path d="M5 8l2 2 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </span>
        </label>
      ))}
    </div>
  </div>

  <!-- ── Step 3: Users ─────────────────────────────────────── -->
  <div id="step-3" class="wizard-step hidden" role="group" aria-labelledby="step3-legend">
    <p id="step3-legend" class="font-display font-semibold text-bnc-ink dark:text-bnc-paper mb-6" style="font-size: var(--fs-28)">
      {isEn ? 'Who will use this system?' : 'Siapa yang akan menggunakan sistem ini?'}
    </p>
    <div class="grid grid-cols-1 gap-3">
      {[
        { value: 'internal', icon: '🏢', label: isEn ? 'Internal team only' : 'Tim internal saja', desc: isEn ? 'Employees, staff, or a closed group.' : 'Karyawan, staf, atau grup pengguna tertutup.' },
        { value: 'public', icon: '🌍', label: isEn ? 'Public / customer-facing' : 'Publik / menghadap pelanggan', desc: isEn ? 'Open to any end-user or customer.' : 'Terbuka untuk pengguna akhir atau pelanggan mana pun.' },
        { value: 'mixed', icon: '🔀', label: isEn ? 'Mixed (internal + public)' : 'Campuran (internal + publik)', desc: isEn ? 'Staff portal plus customer-facing interface.' : 'Portal staf dan antarmuka menghadap pelanggan.' },
      ].map(opt => (
        <label class="wizard-option" data-step="3" data-value={opt.value} tabindex="0">
          <input type="radio" name="users" value={opt.value} class="sr-only" />
          <span class="option-icon" aria-hidden="true">{opt.icon}</span>
          <span class="option-body">
            <span class="option-label">{opt.label}</span>
            <span class="option-desc">{opt.desc}</span>
          </span>
          <span class="option-check" aria-hidden="true">
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><circle cx="8" cy="8" r="7" stroke="currentColor" stroke-width="1.5"/><path d="M5 8l2 2 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </span>
        </label>
      ))}
    </div>
  </div>

  <!-- ── Step 4: Features (multi-select) ──────────────────── -->
  <div id="step-4" class="wizard-step hidden" role="group" aria-labelledby="step4-legend">
    <p id="step4-legend" class="font-display font-semibold text-bnc-ink dark:text-bnc-paper mb-2" style="font-size: var(--fs-28)">
      {isEn ? 'Which features does your project need?' : 'Fitur apa saja yang dibutuhkan proyek Anda?'}
    </p>
    <p class="text-bnc-stone-500 dark:text-bnc-stone-400 text-sm mb-6">
      {isEn ? 'Select all that apply. Skip if none apply.' : 'Pilih semua yang relevan. Bisa dilewati jika tidak ada.'}
    </p>
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
      {[
        { value: 'auth-roles', icon: '🔐', label: isEn ? 'Auth & Roles' : 'Autentikasi & Peran', desc: isEn ? 'Login, permissions, role-based access.' : 'Login, izin akses, kontrol berbasis peran.' },
        { value: 'payments', icon: '💳', label: isEn ? 'Payments' : 'Pembayaran', desc: isEn ? 'Payment gateway, invoicing, billing.' : 'Payment gateway, faktur, penagihan.' },
        { value: 'realtime', icon: '⚡', label: 'Real-time', desc: isEn ? 'Live updates, WebSocket, chat.' : 'Pembaruan langsung, WebSocket, obrolan.' },
        { value: 'offline', icon: '📶', label: 'Offline mode', desc: isEn ? 'Works without internet connection.' : 'Berjalan tanpa koneksi internet.' },
        { value: 'push', icon: '🔔', label: isEn ? 'Push notifications' : 'Notifikasi push', desc: isEn ? 'Mobile or web push notifications.' : 'Notifikasi push mobile atau web.' },
        { value: 'external-api', icon: '🔗', label: isEn ? 'External API' : 'API Eksternal', desc: isEn ? 'Third-party integrations (maps, SMS, etc.)' : 'Integrasi pihak ketiga (peta, SMS, dll.)' },
        { value: 'admin-panel', icon: '🛠️', label: isEn ? 'Admin panel' : 'Panel admin', desc: isEn ? 'Back-office for managing content and users.' : 'Back-office untuk mengelola konten dan pengguna.' },
        { value: 'reporting', icon: '📈', label: isEn ? 'Reporting & Analytics' : 'Laporan & Analitik', desc: isEn ? 'Charts, exports, custom dashboards.' : 'Grafik, ekspor, dasbor kustom.' },
        { value: 'multi-language', icon: '🌐', label: isEn ? 'Multi-language' : 'Multi-bahasa', desc: isEn ? 'i18n support for 2+ languages.' : 'Dukungan i18n untuk 2+ bahasa.' },
        { value: 'e-sign', icon: '✍️', label: 'E-sign / E-stamp', desc: isEn ? 'Digital signatures or official stamps.' : 'Tanda tangan digital atau cap resmi.' },
        { value: 'file-handling', icon: '📁', label: isEn ? 'File handling' : 'Manajemen file', desc: isEn ? 'Upload, storage, document processing.' : 'Unggah, penyimpanan, pemrosesan dokumen.' },
      ].map(opt => (
        <label class="wizard-option wizard-option-check" data-step="4" data-value={opt.value} tabindex="0">
          <input type="checkbox" name="features" value={opt.value} class="sr-only" />
          <span class="option-icon" aria-hidden="true">{opt.icon}</span>
          <span class="option-body">
            <span class="option-label">{opt.label}</span>
            <span class="option-desc">{opt.desc}</span>
          </span>
          <span class="option-check" aria-hidden="true">
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><rect x="1" y="1" width="14" height="14" rx="3" stroke="currentColor" stroke-width="1.5"/><path d="M4 8l3 3 5-5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </span>
        </label>
      ))}
    </div>
  </div>

  <!-- ── Step 5: Design level ──────────────────────────────── -->
  <div id="step-5" class="wizard-step hidden" role="group" aria-labelledby="step5-legend">
    <p id="step5-legend" class="font-display font-semibold text-bnc-ink dark:text-bnc-paper mb-6" style="font-size: var(--fs-28)">
      {isEn ? 'What level of design do you need?' : 'Tingkat desain apa yang Anda butuhkan?'}
    </p>
    <div class="grid grid-cols-1 gap-3">
      {[
        { value: 'template', icon: '🎨', label: isEn ? 'Template-based' : 'Berbasis template', desc: isEn ? 'Adapts an existing component library. Faster and more cost-efficient.' : 'Mengadaptasi library komponen yang ada. Lebih cepat dan efisien biaya.' },
        { value: 'custom', icon: '✏️', label: isEn ? 'Custom UX/UI' : 'UX/UI kustom', desc: isEn ? 'Full design from wireframes. Unique look and feel for your product.' : 'Desain penuh dari wireframe. Tampilan unik untuk produk Anda.' },
        { value: 'design-system', icon: '🏛️', label: isEn ? 'Full design system' : 'Design system lengkap', desc: isEn ? 'Tokens, component library, and guidelines. Scales across multiple products.' : 'Token, library komponen, dan panduan. Skala di beberapa produk.' },
      ].map(opt => (
        <label class="wizard-option" data-step="5" data-value={opt.value} tabindex="0">
          <input type="radio" name="design" value={opt.value} class="sr-only" />
          <span class="option-icon" aria-hidden="true">{opt.icon}</span>
          <span class="option-body">
            <span class="option-label">{opt.label}</span>
            <span class="option-desc">{opt.desc}</span>
          </span>
          <span class="option-check" aria-hidden="true">
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><circle cx="8" cy="8" r="7" stroke="currentColor" stroke-width="1.5"/><path d="M5 8l2 2 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </span>
        </label>
      ))}
    </div>
  </div>

  <!-- ── Step 6: Urgency ───────────────────────────────────── -->
  <div id="step-6" class="wizard-step hidden" role="group" aria-labelledby="step6-legend">
    <p id="step6-legend" class="font-display font-semibold text-bnc-ink dark:text-bnc-paper mb-6" style="font-size: var(--fs-28)">
      {isEn ? 'What is your timeline expectation?' : 'Apa ekspektasi timeline Anda?'}
    </p>
    <div class="grid grid-cols-1 gap-3">
      {[
        { value: 'standard', icon: '📅', label: isEn ? 'Standard timeline' : 'Timeline standar', desc: isEn ? 'Natural pacing for quality delivery. No premium.' : 'Pacing alami untuk kualitas pengiriman. Tanpa biaya tambahan.' },
        { value: 'rush', icon: '⚡', label: isEn ? 'Aggressive / Rush' : 'Agresif / Rush', desc: isEn ? 'Compressed schedule. Adds ~35% to estimate due to extra resourcing.' : 'Jadwal yang dipadatkan. Menambah ~35% estimasi karena sumber daya ekstra.' },
      ].map(opt => (
        <label class="wizard-option" data-step="6" data-value={opt.value} tabindex="0">
          <input type="radio" name="urgency" value={opt.value} class="sr-only" />
          <span class="option-icon" aria-hidden="true">{opt.icon}</span>
          <span class="option-body">
            <span class="option-label">{opt.label}</span>
            <span class="option-desc">{opt.desc}</span>
          </span>
          <span class="option-check" aria-hidden="true">
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><circle cx="8" cy="8" r="7" stroke="currentColor" stroke-width="1.5"/><path d="M5 8l2 2 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </span>
        </label>
      ))}
    </div>
  </div>

  <!-- ── Step 7: Maintenance ──────────────────────────────── -->
  <div id="step-7" class="wizard-step hidden" role="group" aria-labelledby="step7-legend">
    <p id="step7-legend" class="font-display font-semibold text-bnc-ink dark:text-bnc-paper mb-6" style="font-size: var(--fs-28)">
      {isEn ? 'Do you need ongoing maintenance?' : 'Apakah Anda memerlukan pemeliharaan berkelanjutan?'}
    </p>
    <div class="grid grid-cols-1 gap-3">
      {[
        { value: 'one-time', icon: '📦', label: isEn ? 'One-time delivery' : 'Pengiriman sekali', desc: isEn ? 'Deliver the project, then it is in your hands.' : 'Selesaikan proyek, lalu diserahkan ke Anda.' },
        { value: 'ongoing', icon: '🔄', label: isEn ? 'Ongoing engagement' : 'Kerjasama berkelanjutan', desc: isEn ? 'Monitoring, updates, and minor improvements. Annual estimate shown in output.' : 'Pemantauan, pembaruan, dan perbaikan kecil. Estimasi tahunan ditampilkan di output.' },
      ].map(opt => (
        <label class="wizard-option" data-step="7" data-value={opt.value} tabindex="0">
          <input type="radio" name="maintenance" value={opt.value} class="sr-only" />
          <span class="option-icon" aria-hidden="true">{opt.icon}</span>
          <span class="option-body">
            <span class="option-label">{opt.label}</span>
            <span class="option-desc">{opt.desc}</span>
          </span>
          <span class="option-check" aria-hidden="true">
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><circle cx="8" cy="8" r="7" stroke="currentColor" stroke-width="1.5"/><path d="M5 8l2 2 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </span>
        </label>
      ))}
    </div>
  </div>

  <!-- ── Navigation buttons ──────────────────────────────── -->
  <div class="flex items-center justify-between mt-8 pt-6 border-t border-bnc-stone-200 dark:border-bnc-stone-800">
    <button
      id="btn-back"
      type="button"
      class="hidden font-mono text-sm text-bnc-stone-500 dark:text-bnc-stone-400 hover:text-bnc-ink dark:hover:text-bnc-paper transition-colors px-4 py-2 rounded-[var(--radius-sm)] hover:bg-bnc-stone-100 dark:hover:bg-bnc-stone-800"
      aria-label={isEn ? 'Go back' : 'Kembali'}
    >
      {isEn ? '← Back' : '← Kembali'}
    </button>
    <span id="back-spacer"></span>

    <button
      id="btn-next"
      type="button"
      disabled
      class="inline-flex items-center gap-2 px-6 py-2.5 rounded-[var(--radius-sm)] bg-bnc-primary text-white font-semibold text-sm transition-all duration-[var(--duration-base)] hover:bg-bnc-accent disabled:opacity-40 disabled:pointer-events-none"
    >
      {isEn ? 'Next →' : 'Lanjut →'}
    </button>
  </div>

</div>

<!-- ══════════════════════════════════════════════════════
     OUTPUT SECTION — populated by TS after final step
══════════════════════════════════════════════════════ -->
<div
  id="estimator-output"
  class="hidden mt-12 pt-10 border-t-2 border-bnc-stone-200 dark:border-bnc-stone-800"
  aria-live="polite"
  aria-label={isEn ? 'Estimate result' : 'Hasil estimasi'}
>
</div>

<!-- Print stylesheet -->
<style>
  @media print {
    #estimator-root { display: none; }
    #estimator-output { display: block !important; }
    .no-print { display: none !important; }
  }
</style>

<style>
  .wizard-option {
    display: flex;
    align-items: flex-start;
    gap: 1rem;
    padding: 1rem 1.25rem;
    border-radius: var(--radius-md);
    border: 1.5px solid var(--color-bnc-stone-200);
    background: var(--color-bnc-paper);
    cursor: pointer;
    transition: border-color var(--duration-base), background var(--duration-base);
    user-select: none;
  }

  :global(.dark) .wizard-option {
    border-color: var(--color-bnc-stone-800);
    background: var(--color-bnc-stone-900);
  }

  .wizard-option:hover,
  .wizard-option:focus-visible {
    border-color: var(--color-bnc-accent);
    outline: none;
  }

  .wizard-option.is-selected {
    border-color: var(--color-bnc-primary);
    background: color-mix(in srgb, var(--color-bnc-primary) 6%, var(--color-bnc-paper));
  }

  :global(.dark) .wizard-option.is-selected {
    border-color: var(--color-bnc-accent);
    background: color-mix(in srgb, var(--color-bnc-accent) 8%, var(--color-bnc-stone-900));
  }

  .option-icon { font-size: 1.25rem; line-height: 1; flex-shrink: 0; margin-top: 2px; }
  .option-body { display: flex; flex-direction: column; gap: 0.2rem; flex: 1; }

  .option-label {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: var(--fs-17);
    color: var(--color-bnc-ink);
  }
  :global(.dark) .option-label { color: var(--color-bnc-paper); }

  .option-desc {
    font-size: var(--fs-14);
    color: var(--color-bnc-stone-500);
    line-height: 1.5;
  }
  :global(.dark) .option-desc { color: var(--color-bnc-stone-400); }

  .option-check {
    flex-shrink: 0;
    color: var(--color-bnc-stone-300);
    transition: color var(--duration-base);
  }
  :global(.dark) .option-check { color: var(--color-bnc-stone-700); }

  .wizard-option.is-selected .option-check { color: var(--color-bnc-primary); }
  :global(.dark) .wizard-option.is-selected .option-check { color: var(--color-bnc-accent); }

  .hidden { display: none !important; }
</style>

<script>
// All innerHTML usage in this script injects only:
// 1. Numbers formatted via toLocaleString (no HTML)
// 2. Our own string constants (step labels, fixed copy)
// 3. Portfolio data loaded from a build-time data attribute (trusted, not user input)
// 4. WhatsApp URL built with encodeURIComponent (safe)
// No raw user-supplied text is ever inserted as HTML.

import { calculate } from '../../lib/estimator'
import type {
  EstimatorInput,
  FeatureKey,
  ProjectType,
  Scale,
  UserType,
  DesignLevel,
  Urgency,
  Maintenance,
} from '../../lib/estimator'
import { contact } from '../../data/contact'

// ─── Types ────────────────────────────────────────────────────────────────
interface WizardState {
  step: number
  type?: ProjectType
  scale?: Scale
  users?: UserType
  features: FeatureKey[]
  design?: DesignLevel
  urgency?: Urgency
  maintenance?: Maintenance
}

type PortfolioEntry = {
  title: string
  client: string
  year: number
  bucket: string
  summary: string
}

const TOTAL_STEPS = 7

function defaultState(): WizardState {
  return { step: 1, features: [] }
}

// ─── Hash serialization ───────────────────────────────────────────────────
function stateToHash(s: WizardState): string {
  const p = new URLSearchParams()
  p.set('step', String(s.step))
  if (s.type) p.set('type', s.type)
  if (s.scale) p.set('scale', s.scale)
  if (s.users) p.set('users', s.users)
  if (s.features.length) p.set('features', s.features.join(','))
  if (s.design) p.set('design', s.design)
  if (s.urgency) p.set('urgency', s.urgency)
  if (s.maintenance) p.set('maintenance', s.maintenance)
  return '#' + p.toString()
}

function hashToState(): WizardState {
  const hash = location.hash.replace(/^#/, '')
  if (!hash) return defaultState()
  const p = new URLSearchParams(hash)
  const rawFeatures = p.get('features')
  return {
    step: Math.max(1, Math.min(TOTAL_STEPS, parseInt(p.get('step') ?? '1', 10) || 1)),
    type: (p.get('type') as ProjectType) || undefined,
    scale: (p.get('scale') as Scale) || undefined,
    users: (p.get('users') as UserType) || undefined,
    features: rawFeatures ? (rawFeatures.split(',') as FeatureKey[]) : [],
    design: (p.get('design') as DesignLevel) || undefined,
    urgency: (p.get('urgency') as Urgency) || undefined,
    maintenance: (p.get('maintenance') as Maintenance) || undefined,
  }
}

