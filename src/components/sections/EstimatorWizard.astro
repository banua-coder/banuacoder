// ─── Render step ──────────────────────────────────────────────────────────
function renderStep(s: WizardState): void {
  for (let i = 1; i <= TOTAL_STEPS; i++) {
    stepEl(i)?.classList.add('hidden')
  }
  stepEl(s.step)?.classList.remove('hidden')

  const fill = getEl('progress-fill')
  if (fill) fill.style.width = `${(s.step / TOTAL_STEPS) * 100}%`

  const labelEl = getEl('step-label')
  if (labelEl) {
    labelEl.textContent = isEn
      ? `Step ${s.step} of ${TOTAL_STEPS}`
      : `Langkah ${s.step} dari ${TOTAL_STEPS}`
  }

  const nameEl = getEl('step-name')
  if (nameEl) nameEl.textContent = stepNames[s.step - 1]

  getEl('wizard-progress-bar-wrapper')?.setAttribute('aria-valuenow', String(s.step))

  document.querySelectorAll<HTMLElement>('[data-dot]').forEach((dot) => {
    const n = parseInt(dot.dataset.dot ?? '0', 10)
    dot.style.background = n <= s.step ? 'var(--color-bnc-accent)' : ''
  })

  restoreSelections(s)

  const back = getEl('btn-back')
  const spacer = getEl('back-spacer')
  if (back && spacer) {
    if (s.step === 1) {
      back.classList.add('hidden')
      spacer.classList.remove('hidden')
    } else {
      back.classList.remove('hidden')
      spacer.classList.add('hidden')
    }
  }

  const next = getEl('btn-next') as HTMLButtonElement | null
  if (next) {
    next.textContent = s.step === TOTAL_STEPS
      ? (isEn ? 'Calculate →' : 'Hitung →')
      : (isEn ? 'Next →' : 'Lanjut →')
    next.disabled = !isStepValid(s)
  }

  const firstOpt = stepEl(s.step)?.querySelector<HTMLElement>('.wizard-option')
  if (firstOpt) setTimeout(() => firstOpt.focus(), 50)
}

function restoreSelections(s: WizardState): void {
  const step = s.step
  document.querySelectorAll<HTMLElement>(`[data-step="${step}"]`).forEach((opt) => {
    opt.classList.remove('is-selected')
    const inp = opt.querySelector<HTMLInputElement>('input')
    if (inp) inp.checked = false
  })

  const values: Record<number, string | FeatureKey[] | undefined> = {
    1: s.type, 2: s.scale, 3: s.users, 4: s.features,
    5: s.design, 6: s.urgency, 7: s.maintenance,
  }
  const val = values[step]
  if (!val) return

  if (Array.isArray(val)) {
    val.forEach((v) => {
      const opt = document.querySelector<HTMLElement>(`[data-step="${step}"][data-value="${v}"]`)
      if (opt) {
        opt.classList.add('is-selected')
        const inp = opt.querySelector<HTMLInputElement>('input')
        if (inp) inp.checked = true
      }
    })
  } else {
    const opt = document.querySelector<HTMLElement>(`[data-step="${step}"][data-value="${val}"]`)
    if (opt) {
      opt.classList.add('is-selected')
      const inp = opt.querySelector<HTMLInputElement>('input')
      if (inp) inp.checked = true
    }
  }
}

function isStepValid(s: WizardState): boolean {
  switch (s.step) {
    case 1: return !!s.type
    case 2: return !!s.scale
    case 3: return !!s.users
    case 4: return true
    case 5: return !!s.design
    case 6: return !!s.urgency
    case 7: return !!s.maintenance
    default: return false
  }
}

// ─── Option select ────────────────────────────────────────────────────────
function handleOptionSelect(opt: HTMLElement, s: WizardState): WizardState {
  const step = parseInt(opt.dataset.step ?? '0', 10)
  const value = opt.dataset.value ?? ''
  const isCheckbox = opt.classList.contains('wizard-option-check')
  const next: WizardState = { ...s, features: [...s.features] }

  if (isCheckbox) {
    if (next.features.includes(value as FeatureKey)) {
      next.features = next.features.filter((f) => f !== value)
    } else {
      next.features.push(value as FeatureKey)
    }
  } else {
    switch (step) {
      case 1: next.type = value as ProjectType; break
      case 2: next.scale = value as Scale; break
      case 3: next.users = value as UserType; break
      case 5: next.design = value as DesignLevel; break
      case 6: next.urgency = value as Urgency; break
      case 7: next.maintenance = value as Maintenance; break
    }
  }
  return next
}

// ─── Navigation ───────────────────────────────────────────────────────────
function advance(s: WizardState): WizardState {
  if (!isStepValid(s) || s.step >= TOTAL_STEPS) return s
  return { ...s, step: s.step + 1 }
}
function goBack(s: WizardState): WizardState {
  return s.step > 1 ? { ...s, step: s.step - 1 } : s
}

// ─── IDR formatter ────────────────────────────────────────────────────────
function fmtIDR(n: number): string {
  return 'Rp ' + n.toLocaleString('id-ID')
}

